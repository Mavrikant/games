# Copy to .env (gitignored) for local dev, set in GitHub Actions for prod.
# Astro exposes PUBLIC_* vars to the client bundle; do NOT add secrets here.

# Analytics (Plausible). Use the per-site script ID from the install snippet
# (the bit after `pa-` in https://plausible.io/js/pa-<ID>.js). Empty -> off.
PUBLIC_PLAUSIBLE_SCRIPT_ID=

# Google AdSense client ID (from AdSense console). Format: ca-pub-XXXXXXXXXXXXXXXX
# Empty -> no AdSense script rendered. Also requires public/ads.txt update.
PUBLIC_ADSENSE_CLIENT=

# AdSense per-position slot IDs (10-digit). Create ad units in
# AdSense > Sites > [karaman.dev] > Get ad code > new unit. Each unit
# returns a data-ad-slot value — paste it below. Empty slot -> that
# position renders nothing (no broken <ins> tags).
PUBLIC_ADSENSE_SLOT_HOMEPAGE=
PUBLIC_ADSENSE_SLOT_GAME=

# Donation links (footer). Any can be empty.
PUBLIC_KOFI_URL=
PUBLIC_BMAC_URL=
PUBLIC_GH_SPONSORS_URL=

# Newsletter (Buttondown). Username only — the bit before @ in the
# embed URL https://buttondown.email/<USER>. Empty -> form hidden.
PUBLIC_BUTTONDOWN_USER=

# Feedback widget (Web3Forms). Access key from web3forms.com — anonymous
# signup (e-mail only, no account). 250 submissions/month free, posts to
# the e-mail you registered with. Empty -> floating "Geri bildirim"
# button hidden across the site.
PUBLIC_WEB3FORMS_KEY=

# Contact + social (privacy + iletisim pages auto-pick these up).
PUBLIC_CONTACT_EMAIL=iletisim@karaman.dev
PUBLIC_TIKTOK_URL=
PUBLIC_INSTAGRAM_URL=
PUBLIC_TWITTER_URL=
PUBLIC_YOUTUBE_URL=
PUBLIC_DISCORD_URL=
