# Copy to .env (gitignored) for local dev, set in GitHub Actions for prod.
# Astro exposes PUBLIC_* vars to the client bundle; do NOT add secrets here.

# Analytics (Plausible). Domain is the property name in Plausible dashboard.
# Empty -> no analytics script rendered.
PUBLIC_PLAUSIBLE_DOMAIN=karaman.dev

# Google AdSense client ID (from AdSense console). Format: ca-pub-XXXXXXXXXXXXXXXX
# Empty -> no AdSense script rendered. Also requires public/ads.txt update.
PUBLIC_ADSENSE_CLIENT=

# Donation links (footer). Any can be empty.
PUBLIC_KOFI_URL=
PUBLIC_BMAC_URL=
PUBLIC_GH_SPONSORS_URL=

# Contact + social (privacy + iletisim pages auto-pick these up).
PUBLIC_CONTACT_EMAIL=iletisim@karaman.dev
PUBLIC_TIKTOK_URL=
PUBLIC_INSTAGRAM_URL=
PUBLIC_TWITTER_URL=
PUBLIC_YOUTUBE_URL=
PUBLIC_DISCORD_URL=
