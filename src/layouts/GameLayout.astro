---
import BaseLayout from './BaseLayout.astro';
import SiteFooter from '@components/SiteFooter.astro';
import ShareButton from '@components/ShareButton.astro';
import '@styles/game-shell.css';

interface Props {
  title: string;
  description?: string;
  controls?: string;
  howToPlay?: string;
  ogImage?: string;
}

const { title, description, controls, howToPlay, ogImage } = Astro.props;

const shareUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
>
  <slot name="head" slot="head" />
  <main class="stage">
    <slot />
    {controls && <p class="hint">{controls}</p>}
    {howToPlay && (
      <details class="howto">
        <summary>Nasıl oynanır?</summary>
        <p>{howToPlay}</p>
      </details>
    )}
    <div class="stage__actions">
      <ShareButton url={shareUrl} title={title} text={description} />
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style is:global>
  .stage__actions {
    display: flex;
    justify-content: center;
    margin-top: 12px;
  }
</style>
