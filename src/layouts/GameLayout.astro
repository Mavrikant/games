---
import BaseLayout from './BaseLayout.astro';
import SiteFooter from '@components/SiteFooter.astro';
import ShareButton from '@components/ShareButton.astro';
import AdSlot from '@components/AdSlot.astro';
import { t, type Lang } from '@shared/i18n';
import '@styles/game-shell.css';

interface HreflangLink {
  lang: string;
  href: string;
}

interface Props {
  title: string;
  h1?: string;
  description?: string;
  controls?: string;
  howToPlay?: string;
  ogImage?: string;
  lang?: Lang;
  hreflangs?: HreflangLink[];
}

const {
  title,
  h1,
  description,
  controls,
  howToPlay,
  ogImage,
  lang = 'tr',
  hreflangs = [],
} = Astro.props;
const heading = h1 ?? title;

const shareUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const subTitle =
  lang === 'en' ? '— free browser game' : '— ücretsiz tarayıcı oyunu';
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  lang={lang}
  hreflangs={hreflangs}
  playSurface={true}
>
  <slot name="head" slot="head" />
  <div class="game-shell-grid">
    <main class="stage">
      <h1 class="stage__title">{heading} <span class="stage__title-sub">{subTitle}</span></h1>
      <slot />
      {description && (
        <p class="stage__intro">{description}</p>
      )}
      {controls && (
        <section class="info-block" aria-labelledby="controls-heading">
          <h2 id="controls-heading" class="info-block__heading">{t('controls.heading', lang)}</h2>
          <p class="hint">{controls}</p>
        </section>
      )}
      {howToPlay && (
        <section class="info-block" aria-labelledby="howto-heading">
          <h2 id="howto-heading" class="info-block__heading">{t('howto.heading', lang)}</h2>
          <details class="howto">
            <summary>{t('howto.summary', lang)}</summary>
            <p>{howToPlay}</p>
          </details>
        </section>
      )}
      <div class="stage__actions">
        <ShareButton url={shareUrl} title={title} text={description} />
      </div>
      <slot name="below" />
    </main>
    <aside class="game-sidebar" aria-label={lang === 'en' ? 'Advertisement' : 'Reklam alanı'}>
      <AdSlot position="sidebar" />
    </aside>
  </div>
  <SiteFooter />
</BaseLayout>

<style is:global>
  .stage__actions {
    display: flex;
    justify-content: center;
    margin-top: 12px;
  }
  .stage__title {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    text-align: center;
    line-height: 1.3;
  }
  .stage__title-sub {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 14px;
  }
  .stage__intro {
    margin: 8px auto 0;
    max-width: 640px;
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.5;
    padding: 0 16px;
  }
  .info-block {
    margin: 16px auto 0;
    max-width: 640px;
    padding: 0 16px;
  }
  .info-block__heading {
    margin: 0 0 6px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-align: center;
  }
  @media (max-width: 480px) {
    .stage__title-sub {
      display: block;
      font-size: 12px;
    }
  }
  /* Game shell grid: stage in column 1, sidebar ad slot in column 2.
     Sidebar is desktop-only (>=1024px) so mobile keeps the existing
     full-width stage layout untouched. */
  .game-shell-grid {
    display: block;
  }
  .game-sidebar {
    display: none;
  }
  @media (min-width: 1024px) {
    .game-shell-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
      align-items: start;
    }
    .game-sidebar {
      display: block;
      position: sticky;
      top: 24px;
    }
  }
</style>
