---
import BaseLayout from './BaseLayout.astro';
import '@styles/game-shell.css';

interface Props {
  title: string;
  description?: string;
  controls?: string;
  ogImage?: string;
}

const { title, description, controls, ogImage } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
>
  <slot name="head" slot="head" />
  <main class="stage">
    <slot />
    {controls && <p class="hint">{controls}</p>}
  </main>
</BaseLayout>
