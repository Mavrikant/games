---
import BaseLayout from './BaseLayout.astro';
import SiteFooter from '@components/SiteFooter.astro';
import ShareButton from '@components/ShareButton.astro';
import '@styles/game-shell.css';

interface Props {
  title: string;
  h1?: string;
  description?: string;
  controls?: string;
  howToPlay?: string;
  ogImage?: string;
}

const { title, h1, description, controls, howToPlay, ogImage } = Astro.props;
const heading = h1 ?? title;

const shareUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
>
  <slot name="head" slot="head" />
  <main class="stage">
    <h1 class="stage__title">{heading} <span class="stage__title-sub">— ücretsiz tarayıcı oyunu</span></h1>
    <slot />
    {controls && <p class="hint">{controls}</p>}
    {howToPlay && (
      <details class="howto">
        <summary>Nasıl oynanır?</summary>
        <p>{howToPlay}</p>
      </details>
    )}
    <div class="stage__actions">
      <ShareButton url={shareUrl} title={title} text={description} />
    </div>
    <slot name="below" />
  </main>
  <SiteFooter />
</BaseLayout>

<style is:global>
  .stage__actions {
    display: flex;
    justify-content: center;
    margin-top: 12px;
  }
  .stage__title {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    text-align: center;
    line-height: 1.3;
  }
  .stage__title-sub {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 14px;
  }
  @media (max-width: 480px) {
    .stage__title-sub {
      display: block;
      font-size: 12px;
    }
  }
</style>
