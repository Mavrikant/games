---
import BaseLayout from './BaseLayout.astro';
import '@styles/game-shell.css';

interface Props {
  title: string;
  description?: string;
  controls?: string;
  howToPlay?: string;
  ogImage?: string;
}

const { title, description, controls, howToPlay, ogImage } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
>
  <slot name="head" slot="head" />
  <main class="stage">
    <slot />
    {controls && <p class="hint">{controls}</p>}
    {howToPlay && (
      <details class="howto">
        <summary>Nasıl oynanır?</summary>
        <p>{howToPlay}</p>
      </details>
    )}
  </main>
</BaseLayout>
