---
import '@styles/tokens.css';
import '@styles/base.css';
import FeedbackWidget from '@components/FeedbackWidget.astro';
import StickyAd from '@components/StickyAd.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
}

const {
  title,
  description,
  ogTitle = title,
  ogType = 'website',
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin)
  .href;
// Per-page OG image when provided; otherwise fall back to the brand
// card at /og-default.png so every social share gets a thumbnail.
const ogImagePath = ogImage ?? `${import.meta.env.BASE_URL}og-default.png`;
const ogImageUrl = new URL(ogImagePath, Astro.site ?? Astro.url.origin).href;

// Analytics + ads — env-driven so dev builds don't ping production endpoints.
// PUBLIC_PLAUSIBLE_SCRIPT_ID is the per-site identifier from the Plausible
// install snippet (the bit after `pa-` in the script URL, e.g.
// `BMAxUwrIK8Icg2HpLysj2`). Empty → no analytics rendered.
// PUBLIC_ADSENSE_CLIENT is the AdSense `ca-pub-…` id. Empty → no ads.
// PUBLIC_FUNDING_CHOICES_ID is the publisher id (`pub-…`, no `ca-` prefix)
// shown in the Funding Choices / Privacy & Messaging console. When set,
// EEA/UK/CH visitors get a GDPR consent banner so personalized ad CPM
// stays unlocked; TR visitors see nothing (geo-handled by Google).
const plausibleId = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_ID ?? '';
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
const fundingChoicesId = import.meta.env.PUBLIC_FUNDING_CHOICES_ID ?? '';
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0b0e" />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="32x32" />
    <link rel="icon" type="image/png" sizes="192x192" href={`${import.meta.env.BASE_URL}icon-192.png`} />
    <link rel="icon" type="image/png" sizes="512x512" href={`${import.meta.env.BASE_URL}icon-512.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.webmanifest`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Oyunlar" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    {
      plausibleId && (
        <script
          is:inline
          async
          src={`https://plausible.io/js/pa-${plausibleId}.js`}
        />
      )
    }
    {
      plausibleId && (
        <script
          is:inline
          set:html={
            'window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()'
          }
        />
      )
    }
    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
    {
      fundingChoicesId && (
        <script
          is:inline
          async
          src={`https://fundingchoicesmessages.google.com/i/${fundingChoicesId}?ers=1`}
        />
      )
    }
    {
      fundingChoicesId && (
        <script
          is:inline
          set:html="(function(){function signalGooglefcPresent(){if(!window.frames['googlefcPresent']){if(document.body){const iframe=document.createElement('iframe');iframe.style='width:0;height:0;border:none;z-index:-1000;left:-1000px;top:-1000px';iframe.style.display='none';iframe.name='googlefcPresent';document.body.appendChild(iframe);}else{setTimeout(signalGooglefcPresent,0);}}}signalGooglefcPresent();})();"
        />
      )
    }
    <slot name="head" />
  </head>
  <body>
    <slot />
    <FeedbackWidget />
    <StickyAd />
    <script is:inline>
      // Register service worker (offline support). Runs on https or localhost
      // (both secure contexts) so `npm run preview` can exercise the PWA. A
      // detected update shows a manual refresh toast — no auto-reload.
      (function () {
        var secure =
          location.protocol === 'https:' ||
          location.hostname === 'localhost' ||
          location.hostname === '127.0.0.1';
        if (!('serviceWorker' in navigator) || !secure) return;

        var pendingReload = false;

        function showUpdateToast(worker) {
          if (!worker || document.getElementById('sw-update-toast')) return;
          var bar = document.createElement('div');
          bar.id = 'sw-update-toast';
          bar.style.cssText =
            'position:fixed;right:16px;bottom:16px;z-index:9999;display:flex;' +
            'align-items:center;gap:12px;padding:12px 14px;border-radius:12px;' +
            'background:#14171c;color:#f5f6f8;border:1px solid #2f3540;' +
            'box-shadow:0 8px 30px rgba(0,0,0,.45);' +
            'font:500 14px/1.3 ui-sans-serif,system-ui,sans-serif';
          var label = document.createElement('span');
          label.textContent = 'Yeni sürüm var';
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = 'Yenile';
          btn.style.cssText =
            'cursor:pointer;border:0;border-radius:8px;padding:7px 14px;' +
            'font:inherit;font-weight:600;color:#fff;background:#6366f1';
          btn.addEventListener('click', function () {
            pendingReload = true;
            worker.postMessage({ type: 'SKIP_WAITING' });
          });
          bar.appendChild(label);
          bar.appendChild(btn);
          document.body.appendChild(bar);
        }

        window.addEventListener('load', function () {
          navigator.serviceWorker
            .register('/games/sw.js', { scope: '/games/' })
            .then(function (reg) {
              if (reg.waiting) showUpdateToast(reg.waiting);
              reg.addEventListener('updatefound', function () {
                var nw = reg.installing;
                if (!nw) return;
                nw.addEventListener('statechange', function () {
                  if (nw.state === 'installed' && navigator.serviceWorker.controller) {
                    showUpdateToast(nw);
                  }
                });
              });
            })
            .catch(function () {
              /* registration failed; offline simply unavailable */
            });

          // Reload only after the user accepted the update — never on the
          // first visit when the worker initially takes control.
          navigator.serviceWorker.addEventListener('controllerchange', function () {
            if (pendingReload) location.reload();
          });
        });
      })();
    </script>
    <script is:inline>
      // Install promotion — encourage adding the app to the home screen.
      // Chromium/Android: capture beforeinstallprompt and offer an "Ekle"
      // button. iOS Safari (no such event): show the Share → "Ana Ekrana
      // Ekle" hint on the homepage. Hidden inside the archive iframe, when
      // already installed, or for 14 days after the user dismisses it.
      (function () {
        if (window.top !== window.self) return;
        var standalone =
          window.matchMedia('(display-mode: standalone)').matches ||
          window.navigator.standalone === true;
        if (standalone) return;

        var KEY = 'pwa-install.dismissed';
        var COOLDOWN = 14 * 24 * 60 * 60 * 1000;
        try {
          var raw = localStorage.getItem(KEY);
          if (raw && Date.now() - Number(raw) < COOLDOWN) return;
        } catch (e) {}

        var deferred = null;

        function snooze() {
          try { localStorage.setItem(KEY, String(Date.now())); } catch (e) {}
          var el = document.getElementById('pwa-install');
          if (el) el.remove();
        }

        function showBanner(html, installable) {
          if (document.getElementById('pwa-install')) return;
          var bottom = document.documentElement.classList.contains('has-sticky-ad') ? 84 : 16;
          var bar = document.createElement('div');
          bar.id = 'pwa-install';
          bar.style.cssText =
            'position:fixed;left:16px;bottom:' + bottom + 'px;z-index:9998;max-width:340px;' +
            'display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:14px;' +
            'background:#14171c;color:#f5f6f8;border:1px solid #2f3540;' +
            'box-shadow:0 8px 30px rgba(0,0,0,.45);font:500 13.5px/1.35 ui-sans-serif,system-ui,sans-serif';

          var icon = document.createElement('img');
          icon.src = '/games/icon-192.png';
          icon.alt = '';
          icon.width = 40;
          icon.height = 40;
          icon.style.cssText = 'width:40px;height:40px;border-radius:10px;flex:0 0 auto';
          bar.appendChild(icon);

          var text = document.createElement('div');
          text.style.flex = '1';
          text.innerHTML = html;
          bar.appendChild(text);

          if (installable) {
            var add = document.createElement('button');
            add.type = 'button';
            add.textContent = 'Ekle';
            add.style.cssText =
              'cursor:pointer;border:0;border-radius:8px;padding:8px 14px;font:inherit;' +
              'font-weight:600;color:#fff;background:#6366f1;flex:0 0 auto';
            add.addEventListener('click', function () {
              if (!deferred) return;
              deferred.prompt();
              deferred.userChoice.then(function () {
                try { if (window.plausible) window.plausible('PWA Install'); } catch (e) {}
                deferred = null;
                snooze();
              });
            });
            bar.appendChild(add);
          }

          var close = document.createElement('button');
          close.type = 'button';
          close.setAttribute('aria-label', 'Kapat');
          close.textContent = '×';
          close.style.cssText =
            'cursor:pointer;border:0;background:transparent;color:#98a0ad;font-size:20px;' +
            'line-height:1;padding:2px 4px;flex:0 0 auto';
          close.addEventListener('click', snooze);
          bar.appendChild(close);

          document.body.appendChild(bar);
        }

        window.addEventListener('beforeinstallprompt', function (e) {
          e.preventDefault();
          deferred = e;
          showBanner('Oyunları <b>ana ekrana ekle</b> — tek dokunuşla aç, çevrimdışı oyna.', true);
        });
        window.addEventListener('appinstalled', snooze);

        // iOS Safari has no beforeinstallprompt; nudge with the manual flow,
        // homepage only so it isn't repeated on every game page.
        var ua = navigator.userAgent || '';
        var iosSafari =
          /iphone|ipad|ipod/i.test(ua) && /safari/i.test(ua) && !/crios|fxios|edgios/i.test(ua);
        if (iosSafari && (location.pathname === '/games/' || location.pathname === '/games')) {
          window.addEventListener('load', function () {
            setTimeout(function () {
              showBanner('Ana ekrana eklemek için <b>Paylaş</b> ↑ → <b>“Ana Ekrana Ekle”</b>.', false);
            }, 1500);
          });
        }
      })();
    </script>
  </body>
</html>
