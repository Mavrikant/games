---
import '@styles/tokens.css';
import '@styles/base.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
}

const {
  title,
  description,
  ogTitle = title,
  ogType = 'website',
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin)
  .href;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site ?? Astro.url.origin).href
  : undefined;

// Analytics + ads — env-driven so dev builds don't ping production endpoints.
// PUBLIC_PLAUSIBLE_SCRIPT_ID is the per-site identifier from the Plausible
// install snippet (the bit after `pa-` in the script URL, e.g.
// `BMAxUwrIK8Icg2HpLysj2`). Empty → no analytics rendered.
// PUBLIC_ADSENSE_CLIENT is the AdSense `ca-pub-…` id. Empty → no ads.
const plausibleId = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_ID ?? '';
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0b0e" />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${import.meta.env.BASE_URL}icon-192.png`} />
    <link rel="icon" type="image/png" sizes="512x512" href={`${import.meta.env.BASE_URL}icon-512.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.webmanifest`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="tr_TR" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={ogTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <title>{title}</title>
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    {
      plausibleId && (
        <script
          is:inline
          async
          src={`https://plausible.io/js/pa-${plausibleId}.js`}
        />
      )
    }
    {
      plausibleId && (
        <script
          is:inline
          set:html={
            'window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()'
          }
        />
      )
    }
    {
      adsenseClient && (
        <script
          is:inline
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script is:inline>
      // Register service worker (offline support + install prompt). Only
      // runs on http(s) in production; localhost during dev sees no SW
      // because Astro dev server doesn't serve /sw.js — that's intended.
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/games/sw.js', { scope: '/games/' })
            .catch(() => {
              /* registration failed; offline simply unavailable */
            });
        });
      }
    </script>
  </body>
</html>
