---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import GameLayout from '@layouts/GameLayout.astro';
import RelatedGames from '@components/RelatedGames.astro';
import EmbedCode from '@components/EmbedCode.astro';
import AdSlot from '@components/AdSlot.astro';

const bodyModules = import.meta.glob<{ default: any }>(
  '/src/game-bodies/*.astro',
  { eager: true },
);

const cssModules = import.meta.glob<string>('/src/styles/games/*.css', {
  eager: true,
  query: '?inline',
  import: 'default',
});

export const getStaticPaths: GetStaticPaths = async () => {
  const games = await getCollection('games');
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game, allGames: games },
  }));
};

interface Props {
  game: CollectionEntry<'games'>;
  allGames: CollectionEntry<'games'>[];
}

const { game, allGames } = Astro.props;
const bodyPath = `/src/game-bodies/${game.id}.astro`;
const bodyMod = bodyModules[bodyPath];
if (!bodyMod) {
  throw new Error(
    `No body component found at ${bodyPath} for game '${game.id}'. Add src/game-bodies/${game.id}.astro.`,
  );
}
const Body = bodyMod.default;

const cssKey = `/src/styles/games/${game.id}.css`;
const gameCss = cssModules[cssKey] ?? '';

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL(base, Astro.url.origin);
const gameUrl = new URL(`${base}${game.id}/`, site).href;
const thumbUrl = game.data.thumbnail
  ? new URL(`${base}thumbs/${game.data.thumbnail}`, site).href
  : undefined;
// Twitter / Discord / Slack OG previews don't render SVG — use the
// PNG variant emitted by scripts/gen-og-images.mjs into thumbs/og/.
const ogImagePath = game.data.thumbnail
  ? `${base}thumbs/og/${game.data.thumbnail.replace(/\.svg$/, '.png')}`
  : undefined;

const gameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: game.data.title,
  description: game.data.description,
  url: gameUrl,
  inLanguage: 'tr',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Web Browser',
  genre: game.data.tags,
  datePublished: game.data.dateAdded,
  ...(thumbUrl ? { image: thumbUrl } : {}),
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};

// Breadcrumb: Home → (Category if it has a landing page) → Game.
// FEATURED_CATEGORIES must stay in sync with src/pages/kategori/[tag].astro
// getStaticPaths — otherwise we'd link to a 404.
const FEATURED_CATEGORIES = new Set([
  'puzzle',
  'arcade',
  'refleks',
  'strateji',
  'bulmaca',
  'klasik',
  'kart',
  'kelime',
]);
const CATEGORY_LABELS: Record<string, string> = {
  puzzle: 'Puzzle Oyunları',
  arcade: 'Arcade Oyunları',
  refleks: 'Refleks Oyunları',
  strateji: 'Strateji Oyunları',
  bulmaca: 'Bulmaca Oyunları',
  klasik: 'Klasik Oyunlar',
  kart: 'Kart Oyunları',
  kelime: 'Kelime Oyunları',
};
const primaryCategory = game.data.tags.find((t) => FEATURED_CATEGORIES.has(t));
const breadcrumbItems: { '@type': 'ListItem'; position: number; name: string; item: string }[] = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Ana Sayfa',
    item: new URL(base, site).href,
  },
];
if (primaryCategory) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: CATEGORY_LABELS[primaryCategory] ?? primaryCategory,
    item: new URL(`${base}kategori/${primaryCategory}/`, site).href,
  });
}
breadcrumbItems.push({
  '@type': 'ListItem',
  position: breadcrumbItems.length + 1,
  name: game.data.title,
  item: gameUrl,
});
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};

const faqAnswerHowToPlay =
  game.data.howToPlay ??
  `${game.data.title} oyununu açtığında oyun otomatik olarak başlar. ${game.data.controls ? 'Kontroller: ' + game.data.controls : 'Ekrandaki yönlendirmeleri takip et.'}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `${game.data.title} nasıl oynanır?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faqAnswerHowToPlay,
      },
    },
    {
      '@type': 'Question',
      name: `${game.data.title} ücretsiz mi?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Evet, ${game.data.title} tamamen ücretsizdir. Hiçbir ödeme, abonelik veya satın alma gerekmez. Tarayıcında doğrudan oynayabilirsin.`,
      },
    },
    {
      '@type': 'Question',
      name: `${game.data.title} oynamak için hesap açmam gerekir mi?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayır. Oyunu açıp hemen oynayabilirsin; oynamak için kayıt veya giriş gerekmez. Skorların öntanımlı olarak yalnızca tarayıcının yerel depolamasında saklanır. Yalnızca küresel sıralamaya katılmak istersen Google veya GitHub ile giriş yapabilirsin; bu durumda takma adın ve skorun sıralama sunucusuna gönderilir.',
      },
    },
    {
      '@type': 'Question',
      name: `${game.data.title} mobil cihazda çalışır mı?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Evet. Oyun mobil tarayıcılarda (Safari, Chrome) çalışacak şekilde tasarlanmıştır. Dokunmatik kontroller desteklenir; tablet ve telefondan da rahatça oynayabilirsin.',
      },
    },
    {
      '@type': 'Question',
      name: `${game.data.title} indirmek gerekir mi?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayır, hiçbir indirme veya kurulum gerekmez. Oyun tamamen tarayıcıda çalışır. İstersen sayfayı ana ekranına ekleyip uygulama gibi de kullanabilirsin.',
      },
    },
  ],
};
---

<GameLayout
  title={`${game.data.title} — Tarayıcıda oyna`}
  h1={game.data.title}
  description={game.data.description}
  controls={game.data.controls}
  howToPlay={game.data.howToPlay}
  ogImage={ogImagePath}
  lang="tr"
  hreflangs={game.data.en ? [
    { lang: 'tr', href: gameUrl },
    { lang: 'en', href: new URL(`${base}en/${game.id}/`, site).href },
    { lang: 'x-default', href: gameUrl },
  ] : []}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(gameSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(faqSchema)}
    />
  </Fragment>
  <Body />
  <RelatedGames slot="below" current={game} all={allGames} />
  <AdSlot slot="below" position="game" />
  <EmbedCode slot="below" slug={game.id} title={game.data.title} />
  <AdSlot slot="below" position="footer" />
</GameLayout>

{gameCss && <style is:global set:html={gameCss} />}

<script>
  const loaders = import.meta.glob('/src/game-logic/*.ts');
  const segments = location.pathname.replace(/\/+$/, '').split('/');
  const slug = segments[segments.length - 1];
  const loader = loaders[`/src/game-logic/${slug}.ts`];
  if (loader) {
    loader();
  } else {
    console.error(`No game-logic module for slug '${slug}'`);
  }
</script>
