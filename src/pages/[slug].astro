---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import GameLayout from '@layouts/GameLayout.astro';
import RelatedGames from '@components/RelatedGames.astro';
import EmbedCode from '@components/EmbedCode.astro';
import AdSlot from '@components/AdSlot.astro';

const bodyModules = import.meta.glob<{ default: any }>(
  '/src/game-bodies/*.astro',
  { eager: true },
);

const cssModules = import.meta.glob<string>('/src/styles/games/*.css', {
  eager: true,
  query: '?inline',
  import: 'default',
});

export const getStaticPaths: GetStaticPaths = async () => {
  const games = await getCollection('games');
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game, allGames: games },
  }));
};

interface Props {
  game: CollectionEntry<'games'>;
  allGames: CollectionEntry<'games'>[];
}

const { game, allGames } = Astro.props;
const bodyPath = `/src/game-bodies/${game.id}.astro`;
const bodyMod = bodyModules[bodyPath];
if (!bodyMod) {
  throw new Error(
    `No body component found at ${bodyPath} for game '${game.id}'. Add src/game-bodies/${game.id}.astro.`,
  );
}
const Body = bodyMod.default;

const cssKey = `/src/styles/games/${game.id}.css`;
const gameCss = cssModules[cssKey] ?? '';

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL(base, Astro.url.origin);
const gameUrl = new URL(`${base}${game.id}/`, site).href;
const thumbUrl = game.data.thumbnail
  ? new URL(`${base}thumbs/${game.data.thumbnail}`, site).href
  : undefined;
// Twitter / Discord / Slack OG previews don't render SVG — use the
// PNG variant emitted by scripts/gen-og-images.mjs into thumbs/og/.
const ogImagePath = game.data.thumbnail
  ? `${base}thumbs/og/${game.data.thumbnail.replace(/\.svg$/, '.png')}`
  : undefined;

const gameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: game.data.title,
  description: game.data.description,
  url: gameUrl,
  inLanguage: 'tr',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Web Browser',
  genre: game.data.tags,
  datePublished: game.data.dateAdded,
  ...(thumbUrl ? { image: thumbUrl } : {}),
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<GameLayout
  title={`${game.data.title} — Tarayıcıda oyna`}
  h1={game.data.title}
  description={game.data.description}
  controls={game.data.controls}
  howToPlay={game.data.howToPlay}
  ogImage={ogImagePath}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(gameSchema)}
    />
  </Fragment>
  <Body />
  <RelatedGames slot="below" current={game} all={allGames} />
  <AdSlot slot="below" position="game" />
  <EmbedCode slot="below" slug={game.id} title={game.data.title} />
</GameLayout>

{gameCss && <style is:global set:html={gameCss} />}

<script>
  const loaders = import.meta.glob('/src/game-logic/*.ts');
  const segments = location.pathname.replace(/\/+$/, '').split('/');
  const slug = segments[segments.length - 1];
  const loader = loaders[`/src/game-logic/${slug}.ts`];
  if (loader) {
    loader();
  } else {
    console.error(`No game-logic module for slug '${slug}'`);
  }
</script>
