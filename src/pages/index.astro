---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Card from '@components/Card.astro';
import PlayerOverlay from '@components/PlayerOverlay.astro';
import NewsletterForm from '@components/NewsletterForm.astro';
import SiteFooter from '@components/SiteFooter.astro';
import AdSlot from '@components/AdSlot.astro';
import '@styles/archive.css';

const all = await getCollection('games');
const games = all.sort((a, b) =>
  b.data.dateAdded.localeCompare(a.data.dateAdded),
);

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL(base, Astro.url.origin);

// "Bugünün önerisi" — deterministic day-of-year selection so the featured
// game rotates daily without any server, and rebuilding the same day picks
// the same game.
const _today = new Date();
const _startOfYear = Date.UTC(_today.getUTCFullYear(), 0, 0);
const dayIndex = Math.floor((_today.getTime() - _startOfYear) / 86_400_000);
const featured = games[dayIndex % games.length];
const featuredThumbUrl = featured.data.thumbnail
  ? `${base}thumbs/${featured.data.thumbnail}`
  : null;

// Category shelves above the full grid — surface 6 newest matches per tag
// cluster so casual visitors find something to play before reaching the
// long list (lifts pages/session = ad impressions).
const TAG_SETS: { title: string; eyebrow: string; tags: string[] }[] = [
  {
    title: 'Beyin & Mantık',
    eyebrow: 'Düşünce egzersizi',
    tags: ['puzzle', 'mantık', 'bulmaca'],
  },
  {
    title: 'Refleks & Aksiyon',
    eyebrow: 'Hız ve zamanlama',
    tags: ['arcade', 'refleks', 'reflex'],
  },
  {
    title: 'Sıralı Strateji',
    eyebrow: 'Plan, hamle, kazan',
    tags: ['strateji'],
  },
];
const shelves = TAG_SETS.map((set) => {
  const matchSet = new Set(set.tags);
  const items = games
    .filter((g) => g.data.tags.some((t) => matchSet.has(t)))
    .slice(0, 6);
  return { ...set, games: items };
}).filter((s) => s.games.length > 0);

const gamesData = games.map((g) => ({
  slug: g.id,
  title: g.data.title,
  description: g.data.description,
  dateAdded: g.data.dateAdded,
  tags: g.data.tags,
  controls: g.data.controls ?? '',
  url: `${base}${g.id}/`,
}));

const buildDate = new Date();
const buildDateIso = buildDate.toISOString();
const buildDateLabel = buildDate.toLocaleString('tr-TR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'Europe/Istanbul',
});

const SITE_TITLE = 'Tarayıcı Oyunları — ücretsiz, indirmesiz, anında oyna';
const SITE_DESCRIPTION =
  'Tarayıcıda oynanan ücretsiz oyun arşivi. Snake, XOX ve daha fazlası — indirme yok, hesap yok, reklam yok. Her gün yeni oyun.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tarayıcı Oyunları',
  alternateName: 'karaman.dev/games',
  url: new URL(base, site).href,
  inLanguage: 'tr',
  description: SITE_DESCRIPTION,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${new URL(base, site).href}?q={query}`,
    },
    'query-input': 'required name=query',
  },
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: games.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(`${base}${g.id}/`, site).href,
    name: g.data.title,
  })),
};
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  ogTitle="Tarayıcı Oyunları"
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(websiteSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(itemListSchema)}
    />
  </Fragment>

  <Nav count={games.length} />
  <main id="app" class="app">
    <section class="hero">
      <span class="hero__eyebrow">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
          <circle cx="5" cy="5" r="3" />
        </svg>
        Her gün yeni oyun
      </span>
      <h1 class="hero__title">Tarayıcıda oyna.<br />Klon değil.</h1>
      <p class="hero__subtitle">
        Klasiklere taze mekanik twistleri ve hiç oynamadığın orijinal
        fikirler. Her oyun tek tıkla başlar — indirme, kayıt, reklam yok.
        Türkçe ve ücretsiz; arşive her hafta yeni bir oyun katılır.
      </p>
    </section>

    <section class="featured" aria-labelledby="featured-title">
      <div class="featured__head">
        <span class="featured__eyebrow">Bugünün önerisi</span>
        <span class="featured__done" data-daily-done hidden>
          Bugün oynadın <span aria-hidden="true">✓</span>
        </span>
      </div>
      <button
        class="featured__card"
        data-shelf-slug={featured.id}
        data-daily-challenge
        type="button"
        aria-label={`${featured.data.title} oyna`}
      >
        {featuredThumbUrl && (
          <div class="featured__thumb">
            <img src={featuredThumbUrl} alt="" loading="eager" />
          </div>
        )}
        <div class="featured__body">
          <h2 class="featured__title" id="featured-title">{featured.data.title}</h2>
          <p class="featured__desc">{featured.data.description}</p>
          <span class="featured__cta">Hemen oyna →</span>
        </div>
      </button>
    </section>

    {shelves.map((shelf) => (
      <section class="shelf" aria-label={shelf.title}>
        <header class="shelf__head">
          <span class="shelf__eyebrow">{shelf.eyebrow}</span>
          <h2 class="shelf__title">{shelf.title}</h2>
        </header>
        <div class="shelf__row">
          {shelf.games.map((g) => {
            const thumb = g.data.thumbnail
              ? `${base}thumbs/${g.data.thumbnail}`
              : null;
            return (
              <button
                class="shelf__card"
                data-shelf-slug={g.id}
                type="button"
                aria-label={`${g.data.title} oyna`}
              >
                {thumb ? (
                  <img src={thumb} alt="" loading="lazy" />
                ) : (
                  <span class="shelf__card-thumb-fallback" aria-hidden="true">
                    {g.data.title.charAt(0).toUpperCase()}
                  </span>
                )}
                <span class="shelf__card-title">{g.data.title}</span>
              </button>
            );
          })}
        </div>
      </section>
    ))}

    <div class="toolbar">
      <div class="search">
        <svg
          class="search__icon"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="7" cy="7" r="5" />
          <path d="m11 11 3 3" />
        </svg>
        <input
          id="search"
          class="search__input"
          type="search"
          placeholder="Oyun ara…"
          aria-label="Oyun ara"
        />
      </div>
      <select id="sort" class="sort" aria-label="Sırala">
        <option value="newest">En yeni</option>
        <option value="oldest">En eski</option>
        <option value="alpha">Alfabetik</option>
      </select>
    </div>

    <div id="tags" class="tags"></div>
    <div id="grid" class="grid">
      {games.map((g) => <Card game={g} />)}
    </div>

    <footer class="footer">
      <span>
        Son güncelleme: <time datetime={buildDateIso}>{buildDateLabel}</time>
      </span>
    </footer>
  </main>

  <AdSlot position="homepage" />
  <NewsletterForm />
  <SiteFooter />
  <PlayerOverlay />

  <script
    is:inline
    id="games-data"
    type="application/json"
    set:html={JSON.stringify(gamesData)}
  />

  <script is:inline>
    // Featured and shelf cards trigger the same #/play/<slug> hash that
    // archive/main.ts already listens to (popstate -> syncFromHash ->
    // openGame), so we don't need to import or modify the archive runtime.
    document.addEventListener('click', (e) => {
      const t = e.target;
      const trigger = t && t.closest && t.closest('[data-shelf-slug]');
      if (!trigger) return;
      const slug = trigger.getAttribute('data-shelf-slug');
      if (slug) location.hash = `#/play/${slug}`;
    });
  </script>

  <script>
    import '../archive/main.ts';
    import { isDailyDone, markDailyDone } from '../shared/daily';

    if (isDailyDone()) {
      document.querySelector('[data-daily-done]')?.removeAttribute('hidden');
    }
    document
      .querySelector('[data-daily-challenge]')
      ?.addEventListener('click', () => {
        markDailyDone();
        document
          .querySelector('[data-daily-done]')
          ?.removeAttribute('hidden');
      });
  </script>
</BaseLayout>

<style is:global>
  /* Featured shelf — "Bugünün önerisi" hero spotlight */
  .featured {
    margin: 0 auto 28px;
    max-width: 1024px;
    padding: 0 16px;
  }
  .featured__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .featured__eyebrow {
    display: inline-block;
    color: var(--accent);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .featured__done {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    font-weight: 500;
  }
  .featured__done[hidden] {
    display: none;
  }
  .featured__card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    text-align: left;
    color: var(--text);
    transition: transform 0.18s ease, border-color 0.18s ease;
    font: inherit;
  }
  .featured__card:hover,
  .featured__card:focus-visible {
    transform: translateY(-3px);
    border-color: var(--accent);
    outline: none;
  }
  .featured__thumb {
    aspect-ratio: 16 / 10;
    background: var(--surface-2);
    overflow: hidden;
  }
  .featured__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .featured__body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: center;
  }
  .featured__title {
    font-size: 22px;
    margin: 0;
    line-height: 1.25;
  }
  .featured__desc {
    color: var(--text-muted);
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
  }
  .featured__cta {
    margin-top: 6px;
    color: var(--accent);
    font-weight: 500;
    font-size: 14px;
  }
  @media (min-width: 720px) {
    .featured__card {
      grid-template-columns: minmax(0, 480px) 1fr;
    }
    .featured__body {
      padding: 28px 32px;
      gap: 8px;
    }
    .featured__title {
      font-size: 28px;
    }
  }

  /* Category shelves above the long grid */
  .shelf {
    margin: 0 auto 24px;
    max-width: 1200px;
    padding: 0 16px;
  }
  .shelf__head {
    margin-bottom: 10px;
  }
  .shelf__eyebrow {
    color: var(--text-dim);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .shelf__title {
    font-size: 18px;
    margin: 4px 0 0;
    color: var(--text);
  }
  .shelf__row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }
  .shelf__card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    color: var(--text);
    font: inherit;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .shelf__card:hover,
  .shelf__card:focus-visible {
    transform: translateY(-2px);
    border-color: var(--border-strong);
    outline: none;
  }
  .shelf__card img {
    aspect-ratio: 16 / 10;
    width: 100%;
    object-fit: cover;
    border-radius: 6px;
    display: block;
    background: var(--surface-2);
  }
  .shelf__card-thumb-fallback {
    aspect-ratio: 16 / 10;
    display: grid;
    place-items: center;
    background: var(--surface-2);
    color: var(--text-dim);
    border-radius: 6px;
    font-size: 28px;
    font-weight: 700;
  }
  .shelf__card-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 2px 2px;
  }
  /* On narrow screens swap shelf to a horizontally-scrollable rail so
     more items remain reachable without dominating vertical space. */
  @media (max-width: 640px) {
    .shelf__row {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 10px;
      padding: 4px 16px 12px;
      margin: 0 -16px;
      -webkit-overflow-scrolling: touch;
    }
    .shelf__card {
      flex: 0 0 150px;
      scroll-snap-align: start;
    }
  }
</style>
