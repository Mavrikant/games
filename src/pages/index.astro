---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Card from '@components/Card.astro';
import PlayerOverlay from '@components/PlayerOverlay.astro';
import '@styles/archive.css';

const all = await getCollection('games');
const games = all.sort((a, b) =>
  b.data.dateAdded.localeCompare(a.data.dateAdded),
);

const base = import.meta.env.BASE_URL;
const gamesData = games.map((g) => ({
  slug: g.id,
  title: g.data.title,
  description: g.data.description,
  dateAdded: g.data.dateAdded,
  tags: g.data.tags,
  controls: g.data.controls ?? '',
  url: `${base}${g.id}/`,
}));
const year = new Date().getFullYear();
---

<BaseLayout
  title="Oyunlar — karaman.dev"
  description="Tarayıcı üzerinde çalışan, tamamen statik oyun arşivi. Her gün yeni oyun."
>
  <Nav count={games.length} />
  <main id="app" class="app">
    <section class="hero">
      <span class="hero__eyebrow">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
          <circle cx="5" cy="5" r="3" />
        </svg>
        Her gün yeni oyun
      </span>
      <h1 class="hero__title">Tarayıcıda oyna,<br />indirme yok.</h1>
      <p class="hero__subtitle">
        Tamamen statik bir oyun arşivi. Her oyun doğrudan tarayıcıda çalışır;
        server yok, hesap yok. Klasiklerden deneysel mini-oyunlara açık
        kaynak bir koleksiyon.
      </p>
    </section>

    <div class="toolbar">
      <div class="search">
        <svg
          class="search__icon"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="7" cy="7" r="5" />
          <path d="m11 11 3 3" />
        </svg>
        <input
          id="search"
          class="search__input"
          type="search"
          placeholder="Oyun ara…"
          aria-label="Oyun ara"
        />
      </div>
      <select id="sort" class="sort" aria-label="Sırala">
        <option value="newest">En yeni</option>
        <option value="oldest">En eski</option>
        <option value="alpha">Alfabetik</option>
      </select>
    </div>

    <div id="tags" class="tags"></div>
    <div id="grid" class="grid">
      {games.map((g) => <Card game={g} />)}
    </div>

    <footer class="footer">
      <span>
        &copy; {year} M. Serdar Karaman · Statik &amp; açık kaynak
      </span>
      <a href="https://github.com/Mavrikant/games" target="_blank" rel="noopener">
        github.com/Mavrikant/games ↗
      </a>
    </footer>
  </main>

  <PlayerOverlay />

  <script
    is:inline
    id="games-data"
    type="application/json"
    set:html={JSON.stringify(gamesData)}
  />

  <script>
    import '../archive/main.ts';
  </script>
</BaseLayout>
