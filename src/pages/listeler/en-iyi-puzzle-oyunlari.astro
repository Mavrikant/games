---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Card from '@components/Card.astro';
import PlayerOverlay from '@components/PlayerOverlay.astro';
import SiteFooter from '@components/SiteFooter.astro';
import AdSlot from '@components/AdSlot.astro';
import '@styles/archive.css';
import '@styles/listicle.css';

// Curated picks — order matters. The list is meant to read as a
// "best 12" article, not a sort-by-date dump.
const PICKS = [
  { slug: '2048', tag: 'sayı eşleştirme' },
  { slug: 'sudoku', tag: 'mantık' },
  { slug: 'minesweeper', tag: 'çıkarım' },
  { slug: 'sokoban', tag: 'depo bulmacası' },
  { slug: 'hanoi-kuleleri', tag: 'rekürsif strateji' },
  { slug: 'mahjong-solitaire', tag: 'eşleştirme' },
  { slug: 'mastermind', tag: 'kod kırma' },
  { slug: 'pipe-connect', tag: 'rotasyon' },
  { slug: 'lights-out', tag: 'paralel mantık' },
  { slug: 'dugum-coz', tag: 'düğüm açma' },
  { slug: 'halka-esle', tag: 'eşleştirme' },
  { slug: 'kar-tanesi', tag: 'simetri' },
];

const allGames = await getCollection('games');
const games = PICKS.map((p) => {
  const g = allGames.find((x) => x.id === p.slug);
  return g ? { game: g, tag: p.tag } : null;
}).filter((x): x is { game: typeof allGames[number]; tag: string } => x !== null);

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL(base, Astro.url.origin);
const pageUrl = new URL(`${base}listeler/en-iyi-puzzle-oyunlari/`, site).href;
const gamesData = games.map(({ game: g }) => ({
  slug: g.id,
  title: g.data.title,
  description: g.data.description,
  dateAdded: g.data.dateAdded,
  tags: g.data.tags,
  controls: g.data.controls ?? '',
  url: `${base}${g.id}/`,
}));

const TITLE =
  '2026\'nın en iyi 12 tarayıcı puzzle oyunu — ücretsiz, indirmesiz';
const DESCRIPTION =
  'Tarayıcıda ücretsiz oynanan en iyi 12 puzzle oyunu: 2048, Sudoku, Mahjong Solitaire, Sokoban ve daha fazlası. İndirme gerektirmez, hesap açmaz, anında oyna.';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: TITLE,
  description: DESCRIPTION,
  url: pageUrl,
  inLanguage: 'tr',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: games.map(({ game: g }, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(`${base}${g.id}/`, site).href,
      name: g.data.title,
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Ana Sayfa',
      item: new URL(base, site).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Listeler',
      item: new URL(`${base}listeler/`, site).href,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'En iyi puzzle oyunları',
      item: pageUrl,
    },
  ],
};
---

<BaseLayout title={TITLE} description={DESCRIPTION} ogTitle="En iyi puzzle oyunları" lang="tr">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Nav count={allGames.length} />
  <main class="app listicle">
    <nav class="listicle__crumbs" aria-label="Konum">
      <a href={base}>Ana Sayfa</a>
      <span aria-hidden="true">›</span>
      <span>En iyi puzzle oyunları</span>
    </nav>

    <article class="listicle__intro">
      <h1>2026'nın en iyi 12 tarayıcı puzzle oyunu</h1>
      <p class="listicle__lede">
        Beyin egzersizinden iş arasındaki 5 dakikalık molaya kadar her amaç için
        oynanan bir puzzle var. Bu liste, indirme ve kayıt gerektirmeden
        tarayıcıda anında oynayabileceğin en güzel 12 puzzle'ı bir araya
        getiriyor — klasikler, mantık-çıkarım egzersizleri ve özgün twistler
        karışık.
      </p>
      <p>
        Sıralama hem oyunun zihinsel yoğunluğu hem de oynanış akıcılığı
        gözetilerek hazırlandı. Üst sıralardakiler kavraması saniyeler süren
        ama ustalaşması haftalar alan oyunlar; alt sıralar daha rahat tempolu,
        kısa partiler için ideal. Her kartı tıkladığında oyun direkt açılır,
        skorlar tarayıcının yerel depolamasında saklanır.
      </p>
      <p>
        Tüm oyunlar mobil dokunmatik ile masaüstü klavye/fare üzerinde aynı
        rahatlıkla çalışır. Yeni bir alışkanlık edinmek istersen, alt başlıkta
        her oyunun en güçlü yanını gösterdik — kendi tarzına uyanla başla.
      </p>
    </article>

    <ol class="listicle__list">
      {games.map(({ game: g, tag }, i) => (
        <li class="listicle__item">
          <span class="listicle__rank">{i + 1}</span>
          <div class="listicle__card-wrap">
            <Card game={g} />
            <span class="listicle__hint">Güçlü yan: {tag}</span>
          </div>
        </li>
      ))}
    </ol>

    <AdSlot position="homepage" />

    <section class="listicle__outro">
      <h2>Listeyi nasıl seçtik?</h2>
      <p>
        Her seferinde aynı 10 başlığa düşmemek için seçimde üç ölçüt kullandık:
        kavrama kolaylığı (yeni bir oyuncu 60 saniye içinde başlayabiliyor mu),
        zihinsel derinlik (10 partide bir hâlâ yeni strateji bulabiliyor musun),
        ve oturum esnekliği (5 dakikalık molayla 30 dakikalık seansa aynı oyun
        uyum sağlıyor mu). Liste her ay yenilenir; arşive yeni puzzle
        eklendikçe daha derinleri yukarı çıkar.
      </p>
      <h2>Sıradakiler</h2>
      <p>
        Mantık ve bulmaca arıyorsan{' '}
        <a href={`${base}kategori/puzzle/`}>Puzzle Oyunları</a> ve{' '}
        <a href={`${base}kategori/bulmaca/`}>Bulmaca Oyunları</a> kategorileri
        de senin için. Hız ve refleks tercihi için{' '}
        <a href={`${base}kategori/arcade/`}>Arcade</a> kategorisine bakabilir,
        klasik bir gece istiyorsan{' '}
        <a href={`${base}kategori/klasik/`}>Klasik Oyunlar</a> sayfasını
        ziyaret edebilirsin.
      </p>
    </section>
  </main>

  <SiteFooter />
  <PlayerOverlay />

  <script
    is:inline
    id="games-data"
    type="application/json"
    set:html={JSON.stringify(gamesData)}
  />

  <script>
    import '../../archive/main.ts';
  </script>
</BaseLayout>
