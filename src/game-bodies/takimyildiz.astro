---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Round<span id="round">1</span></div>
  <div class="hud__score">Süre<span id="time">30</span></div>
  <div class="hud__score">Can<span id="lives">♥♥♥</span></div>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Takımyıldız oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Takımyıldız</h2>
      <p id="overlay-msg">Yıldızları 1'den başlayıp sırayla bağla.</p>
      <button id="overlay-btn" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
<div class="actions">
  <button id="undo" class="hud__btn" type="button">Geri al (Z)</button>
  <button id="restart" class="hud__btn" type="button">Yeniden başla (R)</button>
</div>
