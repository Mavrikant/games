---
---

<header class="hud">
  <div class="hud__score">Tur<span id="round">1</span></div>
  <div class="hud__score">Can<span id="lives">3</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <div id="phase" class="phase phase--ready" aria-live="polite">Hazır</div>
  <div id="board" class="board" role="grid" aria-label="Tersine Dizi tahtası"></div>
  <div id="overlay" class="overlay overlay--hidden">
    <div class="overlay__inner">
      <h2 id="overlay-title">Tersine Dizi</h2>
      <p id="overlay-msg">Dizi yanıp söner. Sen ters sırada tıklarsın. Hazır mısın?</p>
      <button id="overlay-action" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
