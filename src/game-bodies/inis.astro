---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score hud__score--meter">
    Yakıt
    <div class="meter"><div id="fuel-bar" class="meter__bar"></div></div>
  </div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="hud hud--readouts">
  <div class="hud__score">Vy<span id="vy">0.0</span></div>
  <div class="hud__score">Vx<span id="vx">0.0</span></div>
  <div class="hud__score">Rüzgâr<span id="wind">→</span></div>
</div>
<div class="board-wrap">
  <canvas id="board" width="480" height="600" aria-label="İniş oyun alanı"></canvas>
  <div id="overlay" class="overlay" role="dialog" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">İniş</h2>
      <p id="overlay-msg">Tek motor, tek tuş.<br />Yumuşak in — yakıtı dikkatli kullan.<br /><strong>Boşluk</strong> basılı: motor</p>
    </div>
  </div>
</div>
