---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Can<span id="lives">3</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div id="board-wrap" class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="480"
    aria-label="Halka Geçidi sahası"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Halka Geçidi</h2>
      <p id="overlay-msg">
        Üç dönen halkanın boşluklarından topu sırayla geçir.
        <br /><small>Tıkla veya dokun: topu o yöne fırlat.</small>
      </p>
      <button id="overlay-btn" class="hud__btn hud__btn--primary" type="button">
        Başla
      </button>
    </div>
  </div>
</div>
