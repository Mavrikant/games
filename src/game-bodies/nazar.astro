---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__best">Rekor<span id="best">0</span></div>
  <div class="hud__lives">Can<span id="lives">●●●</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Nazar oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Nazar</h2>
      <p id="overlay-msg">Sekiz yönde kem gözler açılır. Muskayı çevir, dolmadan savuştur.
        Başlamak için Boşluk'a bas.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-dir="7" type="button" aria-label="Üst-sol">↖</button>
  <button class="touch__btn" data-dir="0" type="button" aria-label="Yukarı">▲</button>
  <button class="touch__btn" data-dir="1" type="button" aria-label="Üst-sağ">↗</button>
  <button class="touch__btn" data-dir="6" type="button" aria-label="Sol">◀</button>
  <button class="touch__btn touch__btn--center" data-action="start" type="button" aria-label="Başla">●</button>
  <button class="touch__btn" data-dir="2" type="button" aria-label="Sağ">▶</button>
  <button class="touch__btn" data-dir="5" type="button" aria-label="Alt-sol">↙</button>
  <button class="touch__btn" data-dir="4" type="button" aria-label="Aşağı">▼</button>
  <button class="touch__btn" data-dir="3" type="button" aria-label="Alt-sağ">↘</button>
</div>
