---
---

<header class="hud">
  <div class="hud__score">Tur<span id="score">1</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Hedef<span id="target">1</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Beş Taş oyun alanı"></canvas>
  <div id="overlay" class="overlay" role="dialog" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Beş Taş</h2>
      <p id="overlay-msg">Boşluk veya zemine tıkla — havadaki taş düşmeden, yerden <strong>1</strong> taş kap. Her tur bir taş daha.</p>
      <button id="start" class="overlay__btn" type="button">Başla</button>
    </div>
  </div>
</div>
