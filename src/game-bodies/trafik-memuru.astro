---
---

<header class="hud">
  <div class="hud__stat">Skor<span id="score">0</span></div>
  <div class="hud__stat">En iyi<span id="best">0</span></div>
  <div class="hud__stat" aria-label="Sinyal">Sinyal<span id="signal">NS</span></div>
  <button id="toggle" class="hud__btn hud__btn--primary" type="button">Sinyali değiştir</button>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Trafik Memuru kavşağı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Trafik Memuru</h2>
      <p id="overlay-msg">Sinyali değiştirmek için boşluğa bas veya kavşağa dokun.</p>
    </div>
  </div>
</div>
