---
---

<header class="hud">
  <div class="hud__score">Süre<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Tahterevalli oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Tahterevalli</h2>
      <p id="overlay-msg">Boşluk: başla · ← → veya A/D ile pivotu kaydır.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-dir="left" type="button">◀</button>
  <button class="touch__btn" data-dir="right" type="button">▶</button>
</div>
