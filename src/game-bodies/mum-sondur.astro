---
---

<header class="hud">
  <div class="hud__score">Seviye<span id="level">1/5</span></div>
  <div class="hud__score">Nefes<span id="puffs">0</span></div>
  <div class="hud__score">Toplam<span id="total">0</span></div>
  <div class="hud__score">Rekor<span id="best">—</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="720"
    height="420"
    aria-label="Mum Söndür sahnesi"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Mum Söndür</h2>
      <p id="overlay-msg">5 seviye, 30 mum.</p>
      <button id="start" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
