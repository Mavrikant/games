---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score hud__lives">Can<span id="lives">3</span></div>
  <div class="hud__score">En iyi<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="kb-target">
  <span class="kb-target__label">Sıradaki</span>
  <span class="kb-target__chip" id="target-chip" aria-label="Hedef renk"></span>
  <span class="kb-target__name" id="target-name">—</span>
</div>
<div class="board-wrap">
  <canvas id="board" width="420" height="560" aria-label="Kabarcık tüpü"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kabarcık</h2>
      <p id="overlay-msg">Hedef rengi gökkuşağı sırasıyla patlat.&#10;Boşluk veya tıkla — başlamak için.</p>
      <button id="overlay-btn" class="hud__btn overlay__btn" type="button">Başla</button>
    </div>
  </div>
</div>
