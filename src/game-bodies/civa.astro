---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Seviye<span id="level">1</span></div>
  <div class="hud__score">Damla<span id="drops">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div id="board-wrap" class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="480"
    aria-label="Cıva tepsisi"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Cıva</h2>
      <p id="overlay-msg">
        Tepsiyi eğ, dağılan damlaları birleştir.
        <br /><small>Ok tuşları, WASD veya parmakla sürükle.</small>
      </p>
      <button id="overlay-btn" class="hud__btn hud__btn--primary" type="button">
        Başla
      </button>
    </div>
  </div>
</div>
