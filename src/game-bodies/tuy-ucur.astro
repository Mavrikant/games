---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="360" height="600" aria-label="Tüy Uçur oyun alanı"></canvas>
  <div class="wind" aria-hidden="true">
    <span class="wind__label">Rüzgâr</span>
    <div class="wind__bar"><div id="wind-indicator" class="wind__indicator"></div></div>
  </div>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Tüy Uçur</h2>
      <p id="overlay-msg">Tüye yakın tıkla — pufla onu duvardaki boşluğa yönlendir.
Klavye: ← → veya A/D ile yatay it · Boşluk ile başla</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-dir="left" type="button">◀ İt</button>
  <button class="touch__btn" data-dir="right" type="button">İt ▶</button>
</div>
