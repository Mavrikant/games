---
---

<header class="hud">
  <div class="hud__stat">Skor<span id="score">0</span></div>
  <div class="hud__stat">En iyi<span id="best">0</span></div>
  <div class="hud__stat">Kuruyan<span id="dried">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div id="garden-wrap" class="garden-wrap">
  <div
    id="garden"
    class="garden"
    role="grid"
    aria-label="Bahçe parselleri"
  ></div>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Bahçevan</h2>
      <p id="overlay-msg">
        6 parselde tohum dik, sula, meyveyi topla. Susuz kalanları kurutma!
      </p>
      <button id="overlay-btn" class="hud__btn hud__btn--primary" type="button">
        Başla
      </button>
    </div>
  </div>
</div>
