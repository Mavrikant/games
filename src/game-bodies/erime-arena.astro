---
---

<div id="ea-root" class="ea-root">
  <header class="hud">
    <div class="hud__score">Kütle<span id="mass">100</span></div>
    <div class="hud__score">Rekor<span id="best">100</span></div>
    <button id="fs" class="hud__btn" type="button" aria-label="Tam ekran">⛶</button>
    <button id="restart" class="hud__btn" type="button">Yeniden doğ</button>
  </header>
  <div id="status" class="ea-status" aria-live="polite">⚪ Çevrimdışı</div>
  <div class="board-wrap">
    <canvas id="board" aria-label="Hücre Savaşı oyun alanı"></canvas>
    <ul id="leaders" class="leaders" aria-label="Sıralama"></ul>
    <button id="eject" class="ea-eject" type="button" aria-label="Yem at (boşluk)">Yem at</button>
    <div id="overlay" class="overlay">
      <div class="overlay__inner">
        <h2 id="overlay-title">Hücre Savaşı</h2>
        <p id="overlay-msg">
          Yemleri ve daha küçük hücreleri yut, büyü; büyüklerden kaç.
        </p>
        <input
          id="name"
          class="ea-name"
          type="text"
          maxlength="14"
          placeholder="Takma adın"
          aria-label="Takma ad"
        />
        <button id="start" class="ea-start" type="button">Başla</button>
      </div>
    </div>
  </div>
</div>
