---
---

<header class="hud">
  <div class="hud__score">Seviye<span id="level">1</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Darbe<span id="strokes">0</span></div>
  <div class="hud__score">Par<span id="par">0</span></div>
  <button id="restart" class="hud__btn" type="button">Sıfırla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Damga oyma alanı"></canvas>
  <div id="overlay" class="overlay overlay--hidden">
    <div class="overlay__inner">
      <h2 id="overlay-title">Damga</h2>
      <p id="overlay-msg">Hedef hücreleri düz darbelerle oy. Yan koruma hücrelerine değme.</p>
      <button id="overlay-btn" class="hud__btn" type="button">Sonraki seviye</button>
    </div>
  </div>
</div>
