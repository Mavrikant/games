---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Bölüm<span id="level">1/5</span></div>
  <div class="hud__score">Iska<span id="misses">0/4</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="520"
    aria-label="Dikiş kumaşı"
  ></canvas>
  <div id="overlay" class="overlay" role="status" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Dikiş</h2>
      <p id="overlay-msg">İğne sabit ritimde aşağı iner. İmleci sırayla bir sonraki vurgulanmış noktaya getir — dört ıska oyunu bitirir.</p>
      <button id="start-btn" class="hud__btn dikis-start" type="button">Başla</button>
    </div>
  </div>
</div>
