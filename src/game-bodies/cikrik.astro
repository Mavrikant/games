---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="640" aria-label="Çıkrık oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Çıkrık</h2>
      <p id="overlay-msg">Çarka bas ve etrafında daireler çizerek çevir. Saat yönü kovayı indirir, ters yön kaldırır. Hazırsan boşluğa bas.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-dir="up" type="button">▲</button>
  <button class="touch__btn" data-dir="down" type="button">▼</button>
</div>
