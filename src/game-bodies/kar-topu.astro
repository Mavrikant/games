---
---

<header class="hud">
  <div class="hud__stat">Mesafe<span id="distance">0 m</span></div>
  <div class="hud__stat">Boy<span id="size">1.0×</span></div>
  <div class="hud__stat">Rekor<span id="best">—</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="640"
    aria-label="Kar topu yokuş aşağı yuvarlanıyor"></canvas>
  <div id="overlay" class="overlay" aria-hidden="false">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kar Topu</h2>
      <p id="overlay-msg">Yokuştan aşağı dön. Karları topla, çamlardan kaç. Başlamak için tıkla veya bir ok tuşuna bas.</p>
      <button id="overlay-start" class="hud__btn hud__btn--accent" type="button">Başla</button>
    </div>
  </div>
</div>
