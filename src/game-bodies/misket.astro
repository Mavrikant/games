---
---

<header class="hud">
  <div class="hud__score">Vurulan<span id="score">0</span></div>
  <div class="hud__score">Atış<span id="shots">0/10</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="520" height="520" aria-label="Misket oyun alanı"></canvas>
  <div id="overlay" class="overlay" role="status" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Misket</h2>
      <p id="overlay-msg"></p>
    </div>
  </div>
</div>
