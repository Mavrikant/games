---
---

<header class="hud">
  <div class="hud__stat">Tur<span id="round">1/5</span></div>
  <div class="hud__stat">Skor<span id="score">0</span></div>
  <div class="hud__stat">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<section class="board-wrap" aria-label="EKG monitörü">
  <canvas
    id="board"
    width="480"
    height="300"
    aria-label="Kalp atışını gösteren EKG dalga formu"
  ></canvas>
  <div id="overlay" class="overlay" aria-hidden="false">
    <div class="overlay__inner">
      <h2 id="overlay-title">Nabız</h2>
      <p id="overlay-msg">
        Hastanın nabız penceresini izle. Pencere kapanınca kaç kez attığını gir. 5 tur.
      </p>
      <button id="overlay-btn" class="overlay__btn" type="button">Başla</button>
    </div>
  </div>
</section>

<div class="guess" role="group" aria-label="Nabız tahmini">
  <div class="guess__row">
    <button id="guess-down" class="guess__nudge" type="button" disabled aria-label="−1">−</button>
    <div class="guess__display">
      <span class="guess__label">Tahmin</span>
      <span id="guess-val" class="guess__val">0</span>
      <span class="guess__unit">darbe</span>
    </div>
    <button id="guess-up" class="guess__nudge" type="button" disabled aria-label="+1">+</button>
  </div>
  <button id="submit-btn" class="guess__submit" type="button" disabled>
    Onayla (Enter)
  </button>
</div>

<p id="feedback" class="feedback" aria-live="polite"></p>
