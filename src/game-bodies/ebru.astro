---
---

<header class="hud">
  <div class="hud__score">Tur<span id="round">1/3</span></div>
  <div class="hud__score">Damla<span id="drops">0/8</span></div>
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">—</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <div id="palette" class="palette" role="toolbar" aria-label="Renk paleti"></div>
  <canvas
    id="board"
    width="640"
    height="480"
    aria-label="Ebru su teknesi"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Ebru</h2>
      <p id="overlay-msg">Hedef noktalardaki renkleri tutturmak için doğru renkten damla bırak.\nYeni damla, eski damlaları su gibi yana iter.</p>
      <button id="start" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
