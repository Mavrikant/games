---
---

<header class="hud">
  <div class="hud__score">Bahşiş<span id="score">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="640"
    height="480"
    aria-label="Hamam Tası oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Hamam Tası</h2>
      <p id="overlay-msg">
        Sol musluk soğuk, sağ musluk sıcak. Tası doldurup karıştır,
        müşterinin termometresine bak ve doğru hararette başına dök.
        60 saniyede en yüksek bahşişi topla.
      </p>
      <button id="overlay-btn" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
