<header class="hud">
  <div class="hud__score">Atış<span id="shots">0</span></div>
  <div class="hud__score">Rekor<span id="best">—</span></div>
  <button id="solve" class="hud__btn" type="button" disabled>Çöz</button>
  <button id="restart" class="hud__btn" type="button">Yeni oyun</button>
</header>
<div id="status" class="kk-status">4 atom gizli. Portlara tıkla, izleri oku.</div>
<div class="board-wrap">
  <div id="board" class="kk-board" role="grid" aria-label="Kara Kutu 8x8 tahta"></div>
</div>
<div id="legend" class="kk-legend">
  <span><b>H</b> yutuldu</span>
  <span><b>R</b> yansıdı</span>
  <span><b>A/B/…</b> aynı harf = aynı ışının giriş+çıkışı</span>
</div>
