---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Çark alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Çark</h2>
      <p id="overlay-msg">Halkaların açıklıkları hizalanınca ateşle.
Fareyle nişan al, tıkla veya boşluğa bas.</p>
    </div>
  </div>
</div>
