---
---

<header class="hud">
  <div class="hud__stat">Sen<span id="score-player">0</span></div>
  <div class="hud__stat">CPU<span id="score-cpu">0</span></div>
  <div class="hud__stat">En iyi<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="640" height="400" aria-label="Pong oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Pong</h2>
      <p id="overlay-msg">Servis için boşluğa bas veya tıkla.</p>
    </div>
  </div>
</div>
