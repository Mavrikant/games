---
---

<header class="hud">
  <div class="hud__score">Yontulan<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="360" aria-label="Kalemtıraş oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kalemtıraş</h2>
      <p id="overlay-msg">Tuşu basılı tut, çubuk yeşil banttayken bırak.

Space veya ekrana tıkla · R: yeniden başla</p>
    </div>
  </div>
</div>
