---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__best">En iyi<span id="best">0</span></div>
  <div class="hud__time">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="600" aria-label="Kement oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kement</h2>
      <p id="overlay-msg">Halkayı şişirmek için basılı tut, bırakınca yakala.&#10;Başlamak için tıkla.</p>
    </div>
  </div>
</div>
