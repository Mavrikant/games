---
---

<header class="hud">
  <div class="hud__score">Bölüm<span id="score">1</span></div>
  <div class="hud__score">Rekor<span id="best">1</span></div>
  <div class="hud__score">Kuyu<span id="wells">0/0</span></div>
  <button id="launch" class="hud__btn" type="button">Fırlat</button>
  <button id="restart" class="hud__btn" type="button">Sıfırla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="360" height="540" aria-label="Yörünge planlama alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Yörünge</h2>
      <p id="overlay-msg">Boş alana dokunup yerçekimi kuyusu bırak. Hazır olunca Fırlat'a bas.</p>
    </div>
  </div>
</div>
