---
---

<header class="hud">
  <div class="hud__stat">Taş<span id="pegs">32</span></div>
  <div class="hud__stat">Hamle<span id="moves">0</span></div>
  <button id="undo" class="hud__btn" type="button" aria-label="Geri al">Geri al</button>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="tt-board-wrap">
  <div id="board" class="tt-board" role="grid" aria-label="Tek Taş 7×7 tahta"></div>
  <div id="status" class="tt-status" aria-live="polite">Bir taş seç, sonra atlama hedefini tıkla.</div>
  <div id="overlay" class="overlay overlay--hidden" aria-hidden="true">
    <div class="overlay__inner">
      <h2 id="overlay-title">Bitti</h2>
      <p id="overlay-msg">—</p>
      <button id="overlay-restart" class="hud__btn hud__btn--accent" type="button">Yeni oyun</button>
    </div>
  </div>
</div>
