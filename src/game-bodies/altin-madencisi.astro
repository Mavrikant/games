---
---

<header class="hud">
  <div class="hud__score">Para<span id="money">0</span></div>
  <div class="hud__score">Hedef<span id="goal">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <div class="hud__score">Seviye<span id="level">1</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="600" aria-label="Altın Madencisi oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Altın Madencisi</h2>
      <p id="overlay-msg">Çengel sağa sola sallanır. Doğru anda fırlat, altını yakala!</p>
      <button id="action" class="hud__btn am-action" type="button">Başla</button>
    </div>
  </div>
</div>
<div class="touch">
  <button id="launch" class="am-launch" type="button" aria-label="Çengeli fırlat">Çengeli Fırlat</button>
</div>
