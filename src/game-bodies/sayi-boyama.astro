---
---

<header class="hud">
  <div class="hud__stat">Süre<span id="time">0:00</span></div>
  <div class="hud__stat">En iyi<span id="best">—</span></div>
  <button id="mode" class="hud__btn" type="button" aria-pressed="false">Mod: Boya</button>
  <button id="size" class="hud__btn" type="button" aria-label="Tahta boyutu">10×10</button>
  <button id="restart" class="hud__btn" type="button">Yeni</button>
</header>
<div class="board-wrap">
  <div id="board" class="ng" role="grid" aria-label="Sayı boyama bulmacası"></div>
  <div id="overlay" class="overlay overlay--hidden" aria-hidden="true">
    <div class="overlay__inner">
      <h2 id="overlay-title">Tamamlandı!</h2>
      <p id="overlay-msg">—</p>
      <button id="overlay-restart" class="hud__btn hud__btn--accent" type="button">Yeni bulmaca</button>
    </div>
  </div>
</div>
