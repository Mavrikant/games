---
---

<header class="hud">
  <div class="hud__stat">Skor<span id="score">0</span></div>
  <div class="hud__stat">En iyi<span id="best">0</span></div>
  <div class="hud__stat" aria-label="Kalan can">Can<span id="lives">3</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div class="board-wrap">
  <canvas id="board" width="480" height="560" aria-label="Dokuma tezgahı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Dokuma</h2>
      <p id="overlay-msg">Yukarıdaki örüntüyü mekikle birebir doku. Boşluk ile başla.</p>
    </div>
  </div>
</div>
<div class="dokuma-touch" aria-hidden="true">
  <button id="touch-up" class="dokuma-touch__btn" type="button">ÜST</button>
  <button id="touch-down" class="dokuma-touch__btn" type="button">ALT</button>
</div>
