---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Yanık<span id="lost">0/3</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="540" aria-label="İtfaiyeci oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">İtfaiyeci</h2>
      <p id="overlay-msg">Hortumu nişanla, alevleri söndür.
↑/↓ ile açıyı ayarla · Boşluk: su püskürt</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-act="up" type="button" aria-label="Hortumu yukarı">▲</button>
  <button class="touch__btn touch__btn--wide" data-act="fire" type="button" aria-label="Su püskürt">💦</button>
  <button class="touch__btn" data-act="down" type="button" aria-label="Hortumu aşağı">▼</button>
</div>
