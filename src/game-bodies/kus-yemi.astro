---
---

<header class="hud">
  <div class="hud__stat">Skor<span id="score">0</span></div>
  <div class="hud__stat">Yem<span id="seeds">24</span></div>
  <div class="hud__stat">Süre<span id="time">60</span></div>
  <div class="hud__stat">En iyi<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="640" height="420" aria-label="Kuş Yemi bahçesi"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kuş Yemi</h2>
      <p id="overlay-msg">Aç kuşu altın çekirdeklere yemle yönlendir. Başlamak için bahçeye dokun veya boşluğa bas.</p>
    </div>
  </div>
</div>
