---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Tur<span id="round">1</span></div>
  <div class="hud__score">Pekmez<span id="supply">100</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="540" aria-label="Pekmez kavanoz doldurma alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Pekmez</h2>
      <p id="overlay-msg">İbriği fareyle (ya da ← →) sağa sola gez, Boşluk veya tıkla ile dök. Her kavanozu kesik çizgiye kadar tam doldur.</p>
      <button id="start" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
