---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Atış<span id="shots">5</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="640" height="400" aria-label="Okçu oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Okçu</h2>
      <p id="overlay-msg">Boşluğu basılı tut ve elmayı vur. ↑ / ↓ ile nişan al.</p>
    </div>
  </div>
</div>
