---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0.0</span></div>
  <div class="hud__score">Rekor<span id="best">0.0</span></div>
  <div class="hud__score">Islaklık<span id="wet">0%</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="720" height="420" aria-label="Şemsiye sahnesi"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Şemsiye</h2>
      <p id="overlay-msg">Ok tuşları (← →) ya da A/D ile şemsiyenin altında kal. Rüzgâr damlaları yana savurur.</p>
      <button id="start" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
