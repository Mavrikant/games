---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="360"
    aria-label="İp Atla oyun alanı"
  ></canvas>
  <div id="overlay" class="overlay" role="dialog" aria-modal="true">
    <div class="overlay__inner">
      <h2 id="overlay-title">İp Atla</h2>
      <p id="overlay-msg">
        İp ayağına gelince Space veya ekrana dokun.
        Her turda ip biraz daha hızlanır.
      </p>
      <button id="overlay-btn" type="button" class="hud__btn">Başla</button>
    </div>
  </div>
</div>
