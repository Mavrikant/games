---
---

<header class="hud">
  <div class="hud__score">Seviye<span id="level-display">1</span><span class="lz-total">/<span id="level-total">6</span></span></div>
  <div class="hud__score">Ayna<span id="mirrors-left">0</span></div>
  <button id="restart" class="hud__btn" type="button">Seviyeyi sıfırla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="560" height="560" aria-label="Lazer ve Ayna bulmaca alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Lazer &amp; Ayna</h2>
      <p id="overlay-msg">Aynaları yerleştirerek lazeri tüm yıldızlara ulaştır.</p>
    </div>
  </div>
</div>
<div id="lz-legend" aria-label="Açıklama">
  <span class="lz-legend__item"><span class="lz-legend__icon lz-legend__icon--src">▶</span>Kaynak</span>
  <span class="lz-legend__item"><span class="lz-legend__icon lz-legend__icon--target">★</span>Hedef</span>
  <span class="lz-legend__item"><span class="lz-legend__icon lz-legend__icon--mirror">/</span>Tıkla → / → \ → kaldır</span>
</div>
<div id="lz-controls">
  <button id="fire-btn" type="button">🔴 Ateşle</button>
  <button id="clear-btn" type="button">🧹 Temizle</button>
</div>
