---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Tur<span id="round">1</span></div>
  <div class="hud__score">Atış<span id="throws">4/4</span></div>
  <div class="hud__score">Rekor<span id="best">—</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="720" aria-label="Curling pisti — buz üstünde taş kaydırma"></canvas>
  <div id="overlay" class="overlay overlay--hidden" aria-hidden="true">
    <div class="overlay__inner">
      <h2 id="overlay-title">Curling</h2>
      <p id="overlay-msg"></p>
      <button id="overlay-action" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
