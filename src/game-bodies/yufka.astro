---
---

<header class="hud">
  <div class="hud__score">Seviye<span id="score">0</span></div>
  <div class="hud__score">Süre<span id="time">90</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="stage"
    width="480"
    height="320"
    aria-label="Yufka açma masası"
  ></canvas>
  <div id="overlay" class="overlay" role="dialog" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Yufka açma</h2>
      <p id="overlay-msg">
        Merdaneyi hamurun üstünde sürükle (basılı tut). Her hücreyi yeşil
        banda taşı; çok inceltirsen yırtar, kalın bırakırsan banda
        oturmaz. 90 saniyede en çok seviye geç.
      </p>
      <button id="overlay-btn" class="hud__btn" type="button">Başla</button>
    </div>
  </div>
</div>
