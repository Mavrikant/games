---
---

<header class="hud">
  <div class="hud__stat">Seviye<span id="level">1</span></div>
  <div class="hud__stat">Hamle<span id="moves">0</span></div>
  <div class="hud__stat">İtme<span id="pushes">0</span></div>
  <div class="hud__stat">En iyi<span id="best">0</span></div>
</header>
<div class="sb-actions" role="group" aria-label="Aksiyonlar">
  <button id="undo" class="hud__btn sb-actions__btn" type="button" aria-label="Son hamleyi geri al">
    <span aria-hidden="true">↶</span> Geri al
  </button>
  <button id="restart" class="hud__btn sb-actions__btn" type="button" aria-label="Seviyeyi sıfırla">
    Sıfırla
  </button>
  <button id="next" class="hud__btn sb-actions__btn" type="button" aria-label="Sonraki seviyeye geç">
    Sonraki →
  </button>
</div>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Sokoban oyun alanı"></canvas>
  <div id="overlay" class="sb-overlay sb-overlay--hidden" aria-hidden="true">
    <div class="sb-overlay__inner">
      <h2 id="overlay-title">Seviye tamamlandı</h2>
      <p id="overlay-msg">Tüm kutular yerinde.</p>
      <button id="overlay-next" class="hud__btn sb-overlay__btn" type="button">Sonraki seviye</button>
    </div>
  </div>
</div>
<div class="sb-touch" role="group" aria-label="Yön tuşları">
  <button class="sb-touch__btn sb-touch__btn--up" data-dir="up" aria-label="Yukarı" type="button">↑</button>
  <button class="sb-touch__btn sb-touch__btn--left" data-dir="left" aria-label="Sol" type="button">←</button>
  <button class="sb-touch__btn sb-touch__btn--down" data-dir="down" aria-label="Aşağı" type="button">↓</button>
  <button class="sb-touch__btn sb-touch__btn--right" data-dir="right" aria-label="Sağ" type="button">→</button>
</div>
