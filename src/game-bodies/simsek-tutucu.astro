---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Can<span id="lives">♥♥♥</span></div>
  <div class="hud__score">Enerji<span id="energy">0/5</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div id="board-wrap" class="board-wrap">
  <canvas
    id="board"
    width="640"
    height="480"
    aria-label="Şimşek Tutucu oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Şimşek Tutucu</h2>
      <p id="overlay-msg">
        Bulutlar şarj olunca dikey şimşek bırakır. Paratoneri konumlandır,
        şimşeği yakala. Bulutlar hareket eder — tahmin et!<br /><small
          >Mouse veya ←/→ · Boşluk: enerji dalgası</small
        >
      </p>
      <button
        id="overlay-btn"
        class="hud__btn hud__btn--primary"
        type="button">Başla</button
      >
    </div>
  </div>
</div>
