---
---

<header class="hud">
  <div class="hud__stat">Skor<span id="score">0</span></div>
  <div class="hud__stat">Rekor<span id="best">0</span></div>
  <button id="toggle" class="hud__btn hud__btn--primary" type="button">Köprüyü Çevir</button>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div class="board-wrap">
  <canvas id="board" width="480" height="540" aria-label="Köprü Bekçisi oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Köprü Bekçisi</h2>
      <p id="overlay-msg">Köprü kapalıyken arabalar, açıkken tekneler geçer.
Boşluk, Enter ya da köprüye tıkla.</p>
    </div>
  </div>
</div>
