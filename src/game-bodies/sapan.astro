---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <div class="hud__score">En iyi<span id="best">—</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="540" aria-label="Sapan oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Sapan</h2>
      <p id="overlay-msg">Sapan çatalına bas, geri-aşağı çek ve bırak. Balonları vur, bombadan kaç. Başlamak için tıkla veya Space.</p>
    </div>
  </div>
</div>
