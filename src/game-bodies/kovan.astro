---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="360" height="360" aria-label="Kovan petek alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kovan</h2>
      <p id="overlay-msg">Arılar petek hücrelerini dolduruyor. Tıkla → hasat et. Dolu bir hücreye yeniden bal akarsa kovan patlar. Hücre ne kadar doluyken hasat edersen skor o kadar yüksek.</p>
      <button id="start" class="hud__btn overlay__btn" type="button">Başla</button>
    </div>
  </div>
</div>
