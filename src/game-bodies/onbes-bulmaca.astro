---
---

<header class="hud">
  <div class="hud__stat">Hamle<span id="moves">0</span></div>
  <div class="hud__stat">Süre<span id="time">0:00</span></div>
  <div class="hud__stat">En iyi<span id="best">—</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="diff" role="group" aria-label="Zorluk">
  <button class="diff__btn" data-size="3" type="button">3×3</button>
  <button class="diff__btn" data-size="4" type="button">4×4</button>
  <button class="diff__btn" data-size="5" type="button">5×5</button>
</div>
<div class="board-wrap">
  <div
    id="board"
    class="board"
    role="grid"
    aria-label="Onbeş Bulmaca tahtası"
  ></div>
  <div id="overlay" class="overlay overlay--hidden" aria-hidden="true">
    <div class="overlay__inner">
      <h2 id="overlay-title">Çözdün!</h2>
      <p id="overlay-msg">—</p>
      <button
        id="overlay-restart"
        class="hud__btn hud__btn--accent"
        type="button">Yeni karışım</button>
    </div>
  </div>
</div>
