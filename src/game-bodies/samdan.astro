---
---

<header class="hud">
  <div class="hud__score">Servis<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Mum<span id="lit">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="540" aria-label="Şamdan denge alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Şamdan</h2>
      <p id="overlay-msg">Salonda parlayan masaya yürü, önünde dur ya da Boşluk'a bas. Ani durup başlama mumları söndürür.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-action="left" type="button">◀</button>
  <button class="touch__btn touch__btn--wide" data-action="serve" type="button">Servis</button>
  <button class="touch__btn" data-action="right" type="button">▶</button>
</div>
