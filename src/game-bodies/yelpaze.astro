---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Bölüm<span id="level">1/5</span></div>
  <div class="hud__score">Can<span id="lives">3/3</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="520"
    aria-label="Yelpaze oyun alanı"
  ></canvas>
  <div id="overlay" class="overlay" role="status" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Yelpaze</h2>
      <p id="overlay-msg">Mum fitilleri 1, 2, 3... sırayla yansın. Fareyi salla — kıvılcımı doğru muma yönlendir, yanlış muma değdirme.</p>
      <button id="start-btn" class="hud__btn yelpaze-start" type="button">Başla</button>
    </div>
  </div>
</div>
