---
---

<header class="hud">
  <div class="hud__score">Tane<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Tur<span id="round">0/8</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="540" aria-label="Harman alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Harman</h2>
      <p id="overlay-msg">Boşluk tuşunu (veya 'Savur' butonunu) basılı tutarak yabayı doldurup bırakınca savur. Rüzgar samanı sürükler, tane sepete düşer.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-action="left" type="button">◀ Sepet</button>
  <button class="touch__btn touch__btn--wide" data-action="toss" type="button">Savur</button>
  <button class="touch__btn" data-action="right" type="button">Sepet ▶</button>
</div>
