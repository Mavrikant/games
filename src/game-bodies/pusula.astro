---
---

<header class="hud">
  <div class="hud__score">Süre<span id="time">60</span></div>
  <div class="hud__score">Puan<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="hud hud--meta">
  <div class="hud__pill hud__pill--red">
    <span class="hud__pill-label">Kırmızı sapma</span>
    <span id="dev-red" class="hud__pill-value">0°</span>
  </div>
  <div class="hud__pill hud__pill--blue">
    <span class="hud__pill-label">Mavi sapma</span>
    <span id="dev-blue" class="hud__pill-value">0°</span>
  </div>
  <div class="hud__pill hud__pill--sync">
    <span class="hud__pill-label">Eş-zaman</span>
    <span id="sync" class="hud__pill-value">0.0sn</span>
  </div>
</div>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Pusula oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Pusula</h2>
      <p id="overlay-msg">Kırmızı iğneyi ← → ile, mavi iğneyi ↑ ↓ ile kendi hedef dilimleri içinde tut. Başlamak için herhangi bir ok tuşuna bas.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <div class="touch__col">
    <span class="touch__lbl touch__lbl--red">Kırmızı</span>
    <div class="touch__row">
      <button class="touch__btn touch__btn--red" data-act="red-left" type="button" aria-label="Kırmızıyı sola çevir">◀</button>
      <button class="touch__btn touch__btn--red" data-act="red-right" type="button" aria-label="Kırmızıyı sağa çevir">▶</button>
    </div>
  </div>
  <div class="touch__col">
    <span class="touch__lbl touch__lbl--blue">Mavi</span>
    <div class="touch__row">
      <button class="touch__btn touch__btn--blue" data-act="blue-left" type="button" aria-label="Maviyi sola çevir">◀</button>
      <button class="touch__btn touch__btn--blue" data-act="blue-right" type="button" aria-label="Maviyi sağa çevir">▶</button>
    </div>
  </div>
</div>
