---
---

<header class="hud">
  <div class="hud__score">Tur<span id="round">—</span></div>
  <div class="hud__score">Hedef<span id="target">—</span></div>
  <div class="hud__score">Toplam<span id="total">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="next" class="hud__btn" type="button" disabled>Sonraki ▶</button>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>

<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Tam Pay — çokgen kesme alanı"></canvas>
  <div id="overlay" class="overlay" role="dialog" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Tam Pay</h2>
      <p id="overlay-msg">Çokgeni tek bir düz çizgiyle istenen orana göre kes.
10 turda en yüksek skoru hedefle.</p>
      <button id="overlay-btn" class="hud__btn hud__btn--primary" type="button">Başla</button>
    </div>
  </div>
</div>
