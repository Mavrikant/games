---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__ammo">Mühimmat<span id="ammo">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="640" height="400" aria-label="Kuşatma — mancınıkla kaleyi yık"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kuşatma</h2>
      <p id="overlay-msg">Mancınığı geri çekip bırak; surları yıkıp tüm sancakları devir.</p>
      <button id="overlay-btn" class="ks-btn" type="button">Başla</button>
    </div>
  </div>
</div>
