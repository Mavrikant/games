---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Can<span id="lives">3</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="520"
    aria-label="Asansör oyun alanı"
  ></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Asansör</h2>
      <p id="overlay-msg">
        Yolcuları sabırları tükenmeden doğru kata bırak. Başlamak için 1-5 tuşlarına bas
        veya bir kata tıkla.
      </p>
    </div>
  </div>
</div>
<div class="floor-buttons" aria-label="Kat seçici">
  <button class="floor-btn" data-floor="5" type="button">5</button>
  <button class="floor-btn" data-floor="4" type="button">4</button>
  <button class="floor-btn" data-floor="3" type="button">3</button>
  <button class="floor-btn" data-floor="2" type="button">2</button>
  <button class="floor-btn" data-floor="1" type="button">1</button>
</div>
