---
---

<header class="hud">
  <div class="hud__score">Süre<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Su<span id="water">0%</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="600" aria-label="Çatı oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Çatı</h2>
      <p id="overlay-msg">Çatı sızıyor. Delikleri yamala — oda su altında kalmadan dayan. Başlamak için tıkla.</p>
    </div>
  </div>
</div>
