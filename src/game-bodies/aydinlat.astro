---
---

<header class="hud">
  <div class="hud__stat">Bölüm<span id="level">—</span></div>
  <div class="hud__stat">Lamba<span id="bulbs">0</span></div>
  <button id="restart" class="hud__btn" type="button">Sıfırla</button>
</header>
<div class="board-wrap">
  <div id="board" class="ay-board" role="grid" aria-label="Aydınlat tahtası"></div>
  <div id="overlay" class="overlay overlay--hidden" aria-hidden="true">
    <div class="overlay__inner">
      <h2 id="overlay-title">Bölüm tamam!</h2>
      <p id="overlay-msg">—</p>
      <button id="overlay-next" class="hud__btn hud__btn--accent" type="button">Sonraki bölüm</button>
    </div>
  </div>
</div>
