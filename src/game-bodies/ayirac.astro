---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Can<span id="lives">3</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Ayıraç oyun alanı"></canvas>
  <div id="overlay" class="overlay" aria-hidden="false">
    <div class="overlay__inner">
      <h2 id="overlay-title">Ayıraç</h2>
      <p id="overlay-msg">Diski döndür, gelen taneciği renk yuvasına yönlendir.

← → veya A / D ile döndür · Boşluk: Başla</p>
    </div>
  </div>
</div>
