---
---

<header class="hud">
  <div class="hud__score">Gem<span id="score">0</span></div>
  <div class="hud__score">Tur<span id="round">1</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Pus oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Pus</h2>
      <p id="overlay-msg">Sis çökmeden gem yerlerini ezberle. Başlamak için tıkla veya boşluğa bas.</p>
    </div>
  </div>
</div>
