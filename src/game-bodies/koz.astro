---
---

<header class="hud">
  <div class="hud__score">Süre<span id="score">0.0</span></div>
  <div class="hud__score">Rekor<span id="best">0.0</span></div>
  <div class="hud__score">Canlı<span id="alive">7/7</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Köz oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Köz</h2>
      <p id="overlay-msg">Sönmeye yüz tutan korları üfleyerek canlı tut. Bir korı üflemek iki komşusunun oksijenini çalar. Başlamak için bir kora tıkla.</p>
    </div>
  </div>
</div>
