---
---

<header class="hud">
  <div class="hud__score">Patlayan<span id="score">0</span></div>
  <div class="hud__score">Yanan<span id="burned">0</span></div>
  <div class="hud__score">Süre<span id="time">45</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas
    id="board"
    width="480"
    height="480"
    aria-label="Mısır patlatma tenceresi"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Mısır Patlat</h2>
      <p id="overlay-msg">
        Basılı tut: ateş yükselir. Bırak: söner.
        70-80'de patlar, 85+'da yanar.
        Başlamak için tıkla veya Space.
      </p>
    </div>
  </div>
</div>
