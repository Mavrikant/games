---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="640" aria-label="Sarkaç oyun alanı"></canvas>
  <div class="meter" aria-hidden="true">
    <div class="meter__label">Hız</div>
    <div class="meter__bar"><div id="speed-fill" class="meter__fill"></div></div>
  </div>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Sarkaç</h2>
      <p id="overlay-msg">← veya → ile sarkacı pompala. Hızlandıkça daha sert tuğlaları kırarsın.<br/>Boşluk veya bir ok tuşuna basarak başla.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-dir="left" type="button">◀ Pompala</button>
  <button class="touch__btn" data-dir="right" type="button">Pompala ▶</button>
</div>
