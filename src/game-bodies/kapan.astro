---
---

<header class="hud">
  <div class="hud__score">Tur<span id="score">0</span></div>
  <div class="hud__best">Rekor<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="528" height="528" aria-label="Kapan oyun tahtası"></canvas>
  <div id="overlay" class="overlay" role="dialog" aria-live="polite">
    <div class="overlay__inner">
      <h2 id="overlay-title">Kapan</h2>
      <p id="overlay-msg">Bir hücreye dokun: ilk bariyerini koy. Tavşan kenara ulaşmadan kuşat.</p>
      <button id="overlay-btn" class="overlay__btn" type="button">Başla</button>
    </div>
  </div>
</div>
