---
---

<header class="hud">
  <div class="hud__score">Atış<span id="throw">1/5</span></div>
  <div class="hud__score">Toplam (m)<span id="score">0</span></div>
  <div class="hud__score">Rekor (m)<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Çekiç Atma sahası"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Çekiç Atma</h2>
      <p id="overlay-msg">İlk tıkla / SPACE: dönmeye başla
Sonraki tıkla / SPACE: bırak (üst-sol yayda en uzak gider)</p>
    </div>
  </div>
</div>
