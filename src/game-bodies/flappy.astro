---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__best">En iyi<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="640" aria-label="Flappy oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Flappy</h2>
      <p id="overlay-msg">Başlamak için Boşluk'a bas, tıkla ya da dokun.</p>
    </div>
  </div>
</div>
<p class="flappy-hint">Boşluk / tıkla / dokun ile zıpla</p>
