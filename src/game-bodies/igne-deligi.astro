---
---

<header class="hud">
  <div class="hud__stat">İplik<span id="score">0</span></div>
  <div class="hud__stat">Rekor<span id="best">0</span></div>
  <div class="hud__stat">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="600" aria-label="İğne Deliği oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">İğne Deliği</h2>
      <p id="overlay-msg">Fareyi (ya da parmağını) iğne gözünden geçir — Boşluk ile başla.</p>
    </div>
  </div>
</div>
