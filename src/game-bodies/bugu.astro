---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="mirror" width="480" height="320" aria-label="Buharlı ayna"></canvas>
  <div id="overlay" class="overlay overlay--hidden">
    <div class="overlay__inner">
      <h2 id="overlay-title">Buğu</h2>
      <p id="overlay-msg">Aynayı silmeye başla.</p>
    </div>
  </div>
</div>
<div class="choices" id="choices" role="group" aria-label="Cevap seçenekleri"></div>
