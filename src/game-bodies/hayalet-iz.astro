---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">En iyi<span id="best">0</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="480" aria-label="Hayalet İz arenası"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Hayalet İz</h2>
      <p id="overlay-msg">Bir yön tuşuna bas. Geçtiğin yol iki saniye sonra kırmızıya döner — kendine değme.</p>
    </div>
  </div>
</div>
<div class="touch" aria-hidden="true">
  <button class="touch__btn" data-dir="up" type="button" aria-label="Yukarı">▲</button>
  <div class="touch__row">
    <button class="touch__btn" data-dir="left" type="button" aria-label="Sol">◀</button>
    <button class="touch__btn" data-dir="down" type="button" aria-label="Aşağı">▼</button>
    <button class="touch__btn" data-dir="right" type="button" aria-label="Sağ">▶</button>
  </div>
</div>
