---
---

<header class="hud">
  <div class="hud__score">Sek<span id="score">0</span></div>
  <div class="hud__score">Tur<span id="round">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Taş<span id="stones">5</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="720" height="420" aria-label="Taş sektir oyun alanı"></canvas>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Taş Sektir</h2>
      <p id="overlay-msg">Taşın üstüne tıkla ve fırlatmak istediğin yönde sürükle. Düşük açı = çok sekme.</p>
    </div>
  </div>
</div>
