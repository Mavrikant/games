---
---

<header class="hud">
  <div class="hud__score">Skor<span id="score">0</span></div>
  <div class="hud__score">Rekor<span id="best">0</span></div>
  <div class="hud__score">Süre<span id="time">60</span></div>
  <button id="restart" class="hud__btn" type="button">Yeniden başla</button>
</header>
<div class="board-wrap">
  <canvas id="board" width="480" height="640" aria-label="Yel değirmeni oyun alanı"></canvas>
  <div class="meter" aria-hidden="true">
    <div class="meter__label">Güç</div>
    <div class="meter__bar"><div id="power-fill" class="meter__fill"></div></div>
  </div>
  <div id="overlay" class="overlay">
    <div class="overlay__inner">
      <h2 id="overlay-title">Yel Değirmeni</h2>
      <p id="overlay-msg">Değirmenlere tıkla, kanatlarını rüzgâra çevir. Doğru hizalama tam güç üretir.<br/>Boşluk ile başla.</p>
    </div>
  </div>
</div>
