---
const base = import.meta.env.BASE_URL;
const koFiUrl = import.meta.env.PUBLIC_KOFI_URL ?? '';
const bmacUrl = import.meta.env.PUBLIC_BMAC_URL ?? '';
const ghSponsorsUrl = import.meta.env.PUBLIC_GH_SPONSORS_URL ?? '';
const hasDonate = koFiUrl || bmacUrl || ghSponsorsUrl;
---

<footer class="site-footer">
  <nav class="site-footer__links" aria-label="Site bağlantıları">
    <a href={`${base}gizlilik/`}>Gizlilik</a>
    <a href={`${base}iletisim/`}>İletişim</a>
    <a href={`${base}feed.xml`}>RSS</a>
    <a
      href="https://github.com/Mavrikant/games"
      target="_blank"
      rel="noopener noreferrer"
      >GitHub</a
    >
  </nav>

  {
    hasDonate && (
      <div class="site-footer__donate" aria-label="Destek ol">
        <span class="site-footer__donate-label">Destek ol:</span>
        {koFiUrl && (
          <a
            href={koFiUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-event="donate"
          >
            Ko-fi
          </a>
        )}
        {bmacUrl && (
          <a
            href={bmacUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-event="donate"
          >
            Buy Me a Coffee
          </a>
        )}
        {ghSponsorsUrl && (
          <a
            href={ghSponsorsUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-event="donate"
          >
            GitHub Sponsors
          </a>
        )}
      </div>
    )
  }

  <p class="site-footer__copy">
    © {new Date().getFullYear()} karaman.dev — Tüm oyunlar açık kaynak.
  </p>
</footer>

<style>
  .site-footer {
    max-width: 980px;
    margin: 80px auto 32px;
    padding: 32px 20px 0;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 13px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
  }

  .site-footer__links,
  .site-footer__donate {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    justify-content: center;
    align-items: center;
  }

  .site-footer__links a,
  .site-footer__donate a {
    color: var(--text-muted);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s;
  }

  .site-footer__links a:hover,
  .site-footer__donate a:hover {
    color: var(--text);
  }

  .site-footer__donate-label {
    color: var(--text-dim);
    font-size: 12px;
  }

  .site-footer__copy {
    margin: 0;
    font-size: 12px;
    color: var(--text-dim);
  }
</style>
