---
// Responsive AdSense slot. Env-gated: renders nothing if either
// PUBLIC_ADSENSE_CLIENT (ca-pub-…) or the per-position slot ID is missing.
// The loader script is in BaseLayout — this component only adds <ins> +
// the push() trigger so Google fills the slot.
//
// Per-position slot IDs come from env vars created in AdSense console:
//   Sites → karaman.dev → Get ad code → create unit → copy the 10-digit
//   data-ad-slot value → set as repo Variable.

interface Props {
  position: 'homepage' | 'game' | 'sticky' | 'sidebar' | 'in-grid' | 'footer';
  label?: string;
}

const { position, label = 'Reklam' } = Astro.props;

const slotMap: Record<Props['position'], string> = {
  homepage: import.meta.env.PUBLIC_ADSENSE_SLOT_HOMEPAGE ?? '',
  game: import.meta.env.PUBLIC_ADSENSE_SLOT_GAME ?? '',
  sticky: import.meta.env.PUBLIC_ADSENSE_SLOT_STICKY ?? '',
  sidebar: import.meta.env.PUBLIC_ADSENSE_SLOT_SIDEBAR ?? '',
  'in-grid': import.meta.env.PUBLIC_ADSENSE_SLOT_INGRID ?? '',
  footer: import.meta.env.PUBLIC_ADSENSE_SLOT_FOOTER ?? '',
};
const slot = slotMap[position];
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
const enabled = !!client && !!slot;

// Per-position layout knobs. Sticky/sidebar/in-grid have fixed shapes;
// homepage/game/footer use responsive `auto`.
const adFormat: Record<Props['position'], string> = {
  homepage: 'auto',
  game: 'auto',
  footer: 'auto',
  sticky: 'horizontal',
  sidebar: 'vertical',
  'in-grid': 'rectangle',
};
const fullWidth: Record<Props['position'], 'true' | 'false'> = {
  homepage: 'true',
  game: 'true',
  footer: 'true',
  sticky: 'false',
  sidebar: 'false',
  'in-grid': 'false',
};
---

{
  enabled && (
    <aside
      class:list={['adslot', `adslot--${position}`]}
      aria-label={label}
      data-ad-position={position}
    >
      <span class="adslot__label">{label}</span>
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={client}
        data-ad-slot={slot}
        data-ad-format={adFormat[position]}
        data-full-width-responsive={fullWidth[position]}
      />
      <script
        is:inline
        set:html="(adsbygoogle = window.adsbygoogle || []).push({});"
      />
    </aside>
  )
}

<style>
  .adslot {
    margin: 24px auto 0;
    max-width: 728px;
    width: 100%;
    text-align: center;
    min-height: 90px;
  }
  .adslot__label {
    display: block;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  /* Sticky: anchored bottom banner; StickyAd wrapper handles fixed positioning */
  .adslot--sticky {
    margin: 0;
    max-width: 100%;
    min-height: 60px;
  }
  .adslot--sticky .adslot__label {
    display: none;
  }
  .adslot--sticky .adsbygoogle {
    min-height: 60px;
  }
  /* Sidebar: 300x600 — caller hides on <1024px */
  .adslot--sidebar {
    margin: 0;
    max-width: 300px;
    min-height: 600px;
  }
  .adslot--sidebar .adsbygoogle {
    width: 300px;
    height: 600px;
    display: inline-block;
  }
  /* In-grid: matches Card aspect ratio so it slots into the homepage grid */
  .adslot--in-grid {
    margin: 0;
    max-width: 100%;
    min-height: 160px;
    aspect-ratio: 16 / 10;
  }
  .adslot--in-grid .adsbygoogle {
    height: 100%;
    min-height: 160px;
  }
  /* Footer leaderboard under related games */
  .adslot--footer {
    margin-top: 32px;
    min-height: 90px;
  }
</style>
