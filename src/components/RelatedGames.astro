---
import type { CollectionEntry } from 'astro:content';

interface Props {
  current: CollectionEntry<'games'>;
  all: CollectionEntry<'games'>[];
  limit?: number;
}

const { current, all, limit = 4 } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentTags = new Set(current.data.tags);

const ranked = all
  .filter((g) => g.id !== current.id)
  .map((g) => {
    const overlap = g.data.tags.filter((t) => currentTags.has(t)).length;
    return { g, overlap };
  })
  .filter((x) => x.overlap > 0)
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap;
    return b.g.data.dateAdded.localeCompare(a.g.data.dateAdded);
  })
  .slice(0, limit)
  .map((x) => x.g);
---

{
  ranked.length > 0 && (
    <aside class="related" aria-label="İlgili oyunlar">
      <h2 class="related__title">İlgili oyunlar</h2>
      <ul class="related__list">
        {ranked.map((g) => {
          const thumbUrl = g.data.thumbnail
            ? `${base}thumbs/${g.data.thumbnail}`
            : null;
          const placeholder = g.data.title.charAt(0).toUpperCase();
          return (
            <li class="related__item">
              <a class="related__link" href={`${base}${g.id}/`} data-related-slug={g.id}>
                <span class="related__thumb">
                  {thumbUrl ? (
                    <img src={thumbUrl} alt="" loading="lazy" />
                  ) : (
                    <span class="related__thumb-placeholder" aria-hidden="true">
                      {placeholder}
                    </span>
                  )}
                </span>
                <span class="related__name">{g.data.title}</span>
                <span class="related__score" data-related-score hidden />
              </a>
            </li>
          );
        })}
      </ul>
    </aside>
  )
}

<script is:inline>
  // Opportunistic personal-best display. Games store their high score
  // under one of a few common keys (`<slug>.highScore`, `<slug>.bestScore`,
  // …). We poke at each common key; if we find a number, we show it.
  // No key found → the badge stays hidden (graceful no-op).
  (function () {
    const CANDIDATE_SUFFIXES = ['.highScore', '.bestScore', '.best', '.score'];
    document.querySelectorAll('[data-related-slug]').forEach((link) => {
      const slug = link.getAttribute('data-related-slug');
      if (!slug) return;
      let best = null;
      for (const suffix of CANDIDATE_SUFFIXES) {
        try {
          const raw = localStorage.getItem(slug + suffix);
          if (raw === null) continue;
          const parsed = JSON.parse(raw);
          const num = typeof parsed === 'number' ? parsed : Number(parsed);
          if (Number.isFinite(num) && num > 0) {
            best = num;
            break;
          }
        } catch (_) {
          // ignore — storage blocked or non-numeric value
        }
      }
      if (best === null) return;
      const badge = link.querySelector('[data-related-score]');
      if (badge) {
        badge.textContent = 'Son skor: ' + best;
        badge.removeAttribute('hidden');
      }
    });
  })();
</script>

<style>
  .related {
    margin: 24px auto 0;
    max-width: 480px;
    width: 100%;
  }
  .related__title {
    margin: 0 0 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: 0.02em;
  }
  .related__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(96px, 1fr));
    gap: 8px;
  }
  .related__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 8px 6px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition:
      border-color 0.15s,
      background 0.15s;
  }
  .related__link:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }
  .related__thumb {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 6px;
    background: var(--surface-2);
    display: grid;
    place-items: center;
  }
  .related__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .related__thumb-placeholder {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-muted);
  }
  .related__name {
    font-size: 12px;
    font-weight: 500;
    text-align: center;
    line-height: 1.3;
  }
  .related__score {
    font-size: 10px;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .related__score[hidden] {
    display: none;
  }
</style>
