---
---

<section id="player" class="player" aria-hidden="false">
  <div class="player__bar">
    <button id="player-back" class="player__back" type="button" aria-label="Arşive dön">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13 5 8l5-5" />
      </svg>
      Arşiv
    </button>
    <strong id="player-title" class="player__title"></strong>
    <span id="player-controls" class="player__controls"></span>
    <a id="player-open" class="player__open" href="#" target="_blank" rel="noopener">
      Yeni sekme
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 3h7v7M13 3 6 10M11 9v4H3V5h4" />
      </svg>
    </a>
  </div>
  <iframe
    id="player-frame"
    class="player__frame"
    title="Oyun"
    allow="fullscreen; gamepad; autoplay"
    srcdoc='<!doctype html><html lang="tr"><head><meta charset="utf-8"></head><body></body></html>'
  ></iframe>
</section>
