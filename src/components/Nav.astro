---
interface Props {
  count: number;
}
const { count } = Astro.props;
---

<header class="nav">
  <a class="brand" href={import.meta.env.BASE_URL}>
    <span class="brand__logo" aria-hidden="true">K</span>
    <span>karaman.dev</span>
    <span class="brand__sep">/</span>
    <span class="brand__path">games</span>
  </a>
  <nav class="nav__meta">
    <span class="nav__count">{count} oyun</span>
    <a
      class="nav__link"
      href="https://github.com/Mavrikant/games"
      target="_blank"
      rel="noopener">GitHub</a
    >
  </nav>
</header>
