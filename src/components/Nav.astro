---
import { t, type Lang } from '@shared/i18n';

interface Props {
  count: number;
  lang?: Lang;
}
const { count, lang = 'tr' } = Astro.props;
const base = import.meta.env.BASE_URL;
const homeHref = lang === 'en' ? `${base}en/` : base;
const otherLangHref = lang === 'en' ? base : `${base}en/`;
---

<header class="nav">
  <a class="brand" href={homeHref}>
    <span class="brand__logo" aria-hidden="true">K</span>
    <span>karaman.dev</span>
    <span class="brand__sep">/</span>
    <span class="brand__path">{t('site.brandPath', lang)}</span>
  </a>
  <nav class="nav__meta">
    <span class="nav__streak" data-streak hidden title={lang === 'en' ? 'Consecutive visit days' : 'Üst üste ziyaret günleri'}>
      <span aria-hidden="true">🔥</span>
      <span class="nav__streak-count" data-streak-count>0</span>
    </span>
    <button class="nav__install" type="button" data-pwa-install hidden>
      {lang === 'en' ? 'Download' : 'İndir'}
    </button>
    <a class="nav__lang" href={otherLangHref} hreflang={lang === 'en' ? 'tr' : 'en'}>
      {lang === 'en' ? t('lang.switchToTr', 'en') : t('lang.switchToEn', 'tr')}
    </a>
    <span class="nav__count">{t('games.count', lang, { n: count })}</span>
  </nav>
</header>

<script>
  import { updateStreak } from '../shared/daily';

  const days = updateStreak();
  if (days > 1) {
    const el = document.querySelector('[data-streak]') as HTMLElement | null;
    const count = document.querySelector('[data-streak-count]');
    if (el && count) {
      count.textContent = String(days);
      el.removeAttribute('hidden');
    }
  }
</script>

<style>
  .nav__streak {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
    margin-right: 8px;
  }
  .nav__streak[hidden] {
    display: none;
  }
  .nav__streak-count {
    font-variant-numeric: tabular-nums;
  }
  .nav__lang {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 12px;
    margin-right: 12px;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid var(--border);
    transition: color 0.15s, border-color 0.15s;
  }
  .nav__lang:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .nav__install {
    display: inline-flex;
    align-items: center;
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    color: var(--accent);
    font: inherit;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 11px;
    margin-right: 8px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .nav__install:hover {
    background: var(--accent);
    color: #fff;
  }
  .nav__install[hidden] {
    display: none;
  }
</style>
