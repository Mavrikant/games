---
// Embedded newsletter signup. Backend-free; submits directly to the
// provider. Currently wires Buttondown (https://buttondown.email).
// Set PUBLIC_BUTTONDOWN_USER to your username (the bit before @) to
// activate; empty env hides the form entirely.

const buttondownUser = import.meta.env.PUBLIC_BUTTONDOWN_USER ?? '';
---

{
  buttondownUser && (
    <section class="newsletter" aria-label="E-posta bülteni">
      <div class="newsletter__inner">
        <h2 class="newsletter__title">Yeni oyunlardan haberdar ol</h2>
        <p class="newsletter__copy">
          İki haftada bir, eklediğimiz oyunları senin için derliyoruz. Spam yok,
          ne zaman istersen tek tıkla bırak.
        </p>
        <form
          class="newsletter__form"
          data-buttondown-user={buttondownUser}
          action={`https://buttondown.email/api/emails/embed-subscribe/${buttondownUser}`}
          method="post"
          target="popupwindow"
        >
          <label class="newsletter__field">
            <span class="visually-hidden">E-posta adresi</span>
            <input
              type="email"
              name="email"
              required
              placeholder="e-posta adresin"
              autocomplete="email"
              class="newsletter__input"
            />
          </label>
          <button type="submit" class="newsletter__submit">
            Abone ol
          </button>
        </form>
        <script>
          document.addEventListener('submit', (e) => {
            const target = e.target;
            if (!(target instanceof HTMLFormElement)) return;
            if (!target.classList.contains('newsletter__form')) return;
            const user = target.dataset.buttondownUser ?? '';
            if (user) {
              window.open(`https://buttondown.email/${user}`, 'popupwindow');
            }
            const w = window as unknown as { plausible?: (e: string) => void };
            if (typeof w.plausible === 'function') {
              try {
                w.plausible('newsletter:signup');
              } catch {
                /* swallow */
              }
            }
          });
        </script>
        <p class="newsletter__legal">
          E-postan{' '}
          <a href="https://buttondown.email/privacy" target="_blank" rel="noopener noreferrer">Buttondown</a>{' '}
          üzerinde saklanır. Tek tık ile çıkış.
        </p>
      </div>
    </section>
  )
}

<style>
  .newsletter {
    margin: 56px auto 0;
    padding: 0 20px;
    max-width: 680px;
  }
  .newsletter__inner {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 22px;
    text-align: center;
  }
  .newsletter__title {
    margin: 0 0 6px;
    font-size: 18px;
    color: var(--text);
  }
  .newsletter__copy {
    margin: 0 0 16px;
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.5;
  }
  .newsletter__form {
    display: flex;
    gap: 8px;
    max-width: 460px;
    margin: 0 auto;
    flex-wrap: wrap;
    justify-content: center;
  }
  .newsletter__field {
    flex: 1 1 240px;
    min-width: 0;
  }
  .newsletter__input {
    width: 100%;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 10px;
    padding: 10px 12px;
    font: inherit;
    font-size: 14px;
    transition: border-color 0.15s;
  }
  .newsletter__input:focus {
    outline: none;
    border-color: var(--border-strong);
  }
  .newsletter__submit {
    background: var(--accent-strong, var(--text));
    color: #0a0b0e;
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 10px 18px;
    font: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .newsletter__submit:hover {
    opacity: 0.9;
  }
  .newsletter__legal {
    margin: 12px 0 0;
    font-size: 12px;
    color: var(--text-dim);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
